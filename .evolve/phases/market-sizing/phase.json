{
  "name": "market-sizing",
  "archetype": "evaluate",
  "agent": "evolve-market-sizing",
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/market-sizing-report.md"
    ],
    "signals": [
      "market.layers_quantified"
    ]
  },
  "classify": {
    "require_sections": [
      "TAM",
      "SAM",
      "SOM",
      "Methodology and Assumptions"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "business-strategy"
      }
    ]
  },
  "after": "triage"
}
