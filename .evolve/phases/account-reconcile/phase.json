{
  "name": "account-reconcile",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-account-reconcile",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/account-reconcile-report.md"
    ],
    "signals": [
      "reconcile.unexplained_count"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "GL vs Source Balance",
      "Reconciling Items",
      "Adjustments",
      "Sign-off"
    ],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "accounting-close"
      }
    ]
  },
  "after": "triage"
}
