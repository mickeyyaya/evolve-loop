{
  "name": "post-ship-monitor",
  "kind": "llm",
  "optional": true,
  "archetype": "control",
  "agent": "evolve-post-ship-monitor",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "ship.class"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/post-ship-monitor-report.md"
    ],
    "signals": [
      "post_ship.health"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Health Probes",
      "Results",
      "Verdict"
    ],
    "fail_if_empty": true,
    "fail_if_signal": {
      "post_ship.health": "==false"
    },
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "ship.class",
        "op": "==",
        "value": "cycle"
      }
    ]
  },
  "after": "ship"
}
