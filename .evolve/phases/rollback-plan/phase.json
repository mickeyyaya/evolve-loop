{
  "name": "rollback-plan",
  "kind": "llm",
  "optional": true,
  "archetype": "control",
  "agent": "evolve-rollback-plan",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "build.files_touched"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/rollback-plan.md"
    ],
    "signals": [
      "rollback.ready"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Reversion Mechanism",
      "Blast Radius",
      "Verification",
      "Verdict"
    ],
    "fail_if_empty": true,
    "fail_if_signal": {
      "rollback.ready": "==false"
    },
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "build.files_touched",
        "op": "gt",
        "value": 5
      }
    ]
  },
  "after": "audit"
}
