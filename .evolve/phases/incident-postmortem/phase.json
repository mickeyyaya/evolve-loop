{
  "name": "incident-postmortem",
  "archetype": "evaluate",
  "agent": "evolve-incident-postmortem",
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/incident-postmortem-report.md"
    ],
    "signals": [
      "postmortem.action_items_count"
    ]
  },
  "classify": {
    "require_sections": [
      "Impact",
      "Timeline",
      "Root Cause",
      "Action Items"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "ops-incident"
      }
    ]
  },
  "after": "triage"
}
