{
  "name": "dependency-map",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-dependency-map",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/dependency-map-report.md"],
    "signals": ["depmap.count", "depmap.blocker_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Dependencies", "Critical Path", "Blockers"],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "project-management" }
    ]
  },
  "after": "triage"
}
