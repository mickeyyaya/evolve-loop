{
  "name": "risk-register",
  "kind": "llm",
  "optional": true,
  "archetype": "plan",
  "agent": "evolve-risk-register",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/risk-register-report.md"],
    "signals": ["risk.count", "risk.high_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Risks", "Scoring", "Response Strategies", "Owners"],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "project-management" }
    ]
  },
  "after": "triage"
}
