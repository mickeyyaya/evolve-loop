{
  "name": "prd-draft",
  "kind": "llm",
  "optional": true,
  "archetype": "plan",
  "agent": "evolve-prd-draft",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/prd-draft-report.md"],
    "signals": ["prd.requirements_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Problem", "Goals and Success Metrics", "Requirements", "Out of Scope"],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "product-discovery" }
    ]
  },
  "after": "triage"
}
