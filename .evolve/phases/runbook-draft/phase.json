{
  "name": "runbook-draft",
  "kind": "llm",
  "optional": true,
  "archetype": "control",
  "agent": "evolve-runbook-draft",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/runbook-draft-report.md"
    ],
    "signals": [
      "runbook.steps_count"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Trigger",
      "Diagnosis",
      "Resolution Steps",
      "Escalation"
    ],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "ops-incident"
      }
    ]
  },
  "after": "triage"
}
