{
  "name": "license-provenance-audit",
  "archetype": "evaluate",
  "optional": true,
  "agent": "evolve-license-provenance-audit",
  "categories": [
    "supply-chain"
  ],
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "build.files_touched",
      "scout.goal_type"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/license-provenance-audit-report.md"
    ],
    "signals": [
      "license.severity_max",
      "license.incompatible_count"
    ]
  },
  "classify": {
    "require_sections": [
      "New Dependencies",
      "License \u0026 Provenance Findings",
      "Verdict"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "supply-chain"
      }
    ],
    "skip_when": null
  },
  "gates": {},
  "after": "build"
}