{
  "name": "fault-localization",
  "archetype": "plan",
  "agent": "evolve-fault-localization",
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/fault-localization-report.md"
    ],
    "signals": [
      "fault.locations_count",
      "fault.confidence"
    ]
  },
  "classify": {
    "require_sections": [
      "Suspect Ranking",
      "Edit Locations"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "bugfix"
      },
      {
        "field": "tdd.failure_class",
        "op": "eq",
        "value": "code-build-fail"
      },
      {
        "field": "audit.failure_class",
        "op": "eq",
        "value": "code-audit-fail"
      }
    ]
  },
  "after": "triage",
  "optional": true
}
