{
  "name": "okr-draft",
  "archetype": "plan",
  "agent": "evolve-okr-draft",
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/okr-draft-report.md"
    ],
    "signals": [
      "okr.key_results_count"
    ]
  },
  "classify": {
    "require_sections": [
      "Objective",
      "Key Results",
      "Confidence and Scoring"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "business-strategy"
      }
    ]
  },
  "after": "triage",
  "optional": true
}
