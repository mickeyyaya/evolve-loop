{
  "name": "okr-draft",
  "kind": "llm",
  "optional": true,
  "archetype": "plan",
  "agent": "evolve-okr-draft",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/okr-draft-report.md"],
    "signals": ["okr.key_results_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Objective", "Key Results", "Confidence and Scoring"],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "business-strategy" }
    ]
  },
  "after": "triage"
}
