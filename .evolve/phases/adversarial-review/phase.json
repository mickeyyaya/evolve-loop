{
  "name": "adversarial-review",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-adversarial-review",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/build-report.md"],
    "signals": ["build.files_touched", "build.severity_max"]
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/adversarial-review-report.md"],
    "signals": ["adversarial.severity_max", "adversarial.exploit_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Threat Model", "Findings", "Verdict"],
    "fail_if_empty": true,
    "fail_if_signal": { "adversarial.severity_max": ">=HIGH" },
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "build.files_touched", "op": "gt", "value": 0 }
    ]
  },
  "after": "build"
}
