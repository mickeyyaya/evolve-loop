{
  "name": "api-contract-design",
  "kind": "llm",
  "optional": true,
  "archetype": "plan",
  "agent": "evolve-api-contract-design",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": [
      "scout.goal_type"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/api-contract.md"
    ],
    "signals": [
      "contract.surfaces"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Surfaces",
      "Interface Definitions",
      "Invariants",
      "Verdict"
    ],
    "fail_if_empty": true,
    "fail_if_signal": {},
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "feature"
      }
    ]
  },
  "after": "triage"
}
