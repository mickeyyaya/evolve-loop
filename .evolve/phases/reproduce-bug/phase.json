{
  "name": "reproduce-bug",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-reproduce-bug",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md",
      ".evolve/runs/cycle-{cycle}/fault-localization-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/reproduce-bug-report.md"],
    "signals": ["repro.failing", "repro.test_path"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Reproduction", "Verification"],
    "fail_if_signal": { "repro.failing": "==false" },
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "bugfix" }
    ]
  },
  "after": "fault-localization"
}
