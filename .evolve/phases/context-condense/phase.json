{
  "name": "context-condense",
  "kind": "llm",
  "optional": true,
  "archetype": "control",
  "agent": "evolve-context-condense",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": [
      "run_dir.artifact_bytes"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/context-condense-report.md"
    ],
    "signals": [
      "condense.ratio"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Artifacts Scanned",
      "Condensed Digest",
      "Verdict"
    ],
    "fail_if_empty": true,
    "fail_if_signal": {},
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "run_dir.artifact_bytes",
        "op": "gt",
        "value": 102400
      }
    ]
  },
  "after": "triage"
}
