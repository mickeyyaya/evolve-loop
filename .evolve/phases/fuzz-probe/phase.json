{
  "name": "fuzz-probe",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-fuzz-probe",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "build.files_touched"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/fuzz-probe-report.md"
    ],
    "signals": [
      "fuzz.crashers",
      "fuzz.coverage_new"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Target Functions",
      "Fuzz Results",
      "Verdict"
    ],
    "fail_if_empty": true,
    "fail_if_signal": {
      "fuzz.crashers": ">0"
    },
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "build.files_touched",
        "op": "gt",
        "value": 0
      },
      {
        "field": "scout.surface_type",
        "op": "==",
        "value": "parser/decoder/unmarshal"
      }
    ]
  },
  "after": "build"
}
