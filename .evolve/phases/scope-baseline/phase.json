{
  "name": "scope-baseline",
  "archetype": "plan",
  "agent": "evolve-scope-baseline",
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scope-baseline-report.md"
    ],
    "signals": [
      "scope.deliverables_count"
    ]
  },
  "classify": {
    "require_sections": [
      "Deliverables",
      "Acceptance Criteria",
      "Exclusions",
      "Constraints and Assumptions"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "project-management"
      }
    ]
  },
  "after": "triage",
  "optional": true
}
