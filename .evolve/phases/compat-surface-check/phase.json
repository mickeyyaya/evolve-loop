{
  "name": "compat-surface-check",
  "archetype": "evaluate",
  "optional": true,
  "agent": "evolve-compat-surface-check",
  "categories": [
    "api-design"
  ],
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "build.files_touched",
      "scout.goal_type"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/compat-surface-check-report.md"
    ],
    "signals": [
      "compat.severity_max",
      "compat.breaking_count"
    ]
  },
  "classify": {
    "require_sections": [
      "Exported Surface Diff",
      "Breaking Changes",
      "Verdict"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.goal_type",
        "op": "==",
        "value": "api-design"
      }
    ],
    "skip_when": null
  },
  "gates": {},
  "after": "build"
}