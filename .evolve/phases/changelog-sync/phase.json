{
  "name": "changelog-sync",
  "kind": "llm",
  "optional": true,
  "archetype": "control",
  "agent": "evolve-changelog-sync",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "ship.class"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/changelog-sync-report.md"
    ],
    "signals": [
      "changelog.drift_count"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Shipped Commits",
      "Changelog State",
      "Drift",
      "Verdict"
    ],
    "fail_if_empty": true,
    "fail_if_signal": {},
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "ship.class",
        "op": "==",
        "value": "cycle"
      }
    ]
  },
  "after": "ship"
}
