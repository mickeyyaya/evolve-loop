{
  "name": "threat-model",
  "archetype": "plan",
  "agent": "evolve-threat-model",
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/scout-report.md"
    ],
    "signals": []
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/threat-model.md"
    ],
    "signals": [
      "threat.count",
      "threat.severity_max"
    ]
  },
  "classify": {
    "require_sections": [
      "Threats",
      "Mitigations"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "scout.security_relevant",
        "op": "==",
        "value": true
      }
    ]
  },
  "after": "triage",
  "optional": true
}
