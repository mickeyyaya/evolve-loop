{
  "name": "behavior-baseline",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-behavior-baseline",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/behavior-baseline.md"],
    "signals": ["behavior.preserved", "behavior.delta_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Baseline"],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "refactor" }
    ]
  },
  "after": "tdd"
}
