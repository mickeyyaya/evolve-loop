{
  "name": "smell-scan",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-smell-scan",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/smell-scan-report.md"],
    "signals": ["smell.count", "smell.blocker_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Findings"],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "refactor" }
    ]
  },
  "after": "triage"
}
