{
  "name": "mutation-gate",
  "archetype": "evaluate",
  "agent": "evolve-mutation-gate",
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "amplify.tests_added"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/mutation-gate-report.md"
    ],
    "signals": [
      "mutation.score",
      "mutation.survivors"
    ]
  },
  "classify": {
    "require_sections": [
      "Summary",
      "Survivors",
      "Verdict"
    ]
  },
  "routing": {
    "insert_when": [
      {
        "field": "amplify.tests_added",
        "op": "gt",
        "value": 0
      }
    ]
  },
  "after": "test-amplification"
}
