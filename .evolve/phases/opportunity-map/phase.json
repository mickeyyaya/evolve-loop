{
  "name": "opportunity-map",
  "kind": "llm",
  "optional": true,
  "archetype": "plan",
  "agent": "evolve-opportunity-map",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
    "signals": []
  },
  "outputs": {
    "files": [".evolve/runs/cycle-{cycle}/opportunity-map-report.md"],
    "signals": ["opportunity.opportunities_count"]
  },
  "prompt_context": ["goal"],
  "classify": {
    "require_sections": ["Desired Outcome", "Opportunities", "Candidate Solutions", "Assumption Tests"],
    "fail_if_empty": true,
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      { "field": "scout.goal_type", "op": "==", "value": "product-discovery" }
    ]
  },
  "after": "triage"
}
