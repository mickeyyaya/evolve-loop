{
  "name": "benchmark-gate",
  "kind": "llm",
  "optional": true,
  "archetype": "evaluate",
  "agent": "evolve-benchmark-gate",
  "model": "auto",
  "writes_source": false,
  "inputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/build-report.md"
    ],
    "signals": [
      "build.diff_loc",
      "build.files_touched"
    ]
  },
  "outputs": {
    "files": [
      ".evolve/runs/cycle-{cycle}/benchmark-gate-report.md"
    ],
    "signals": [
      "perf.regression_pct",
      "perf.significant"
    ]
  },
  "prompt_context": [
    "goal"
  ],
  "classify": {
    "require_sections": [
      "Benchmarks",
      "Statistical Comparison",
      "Verdict"
    ],
    "fail_if_empty": true,
    "fail_if_signal": {
      "perf.significant": "==true"
    },
    "verdict_on_pass": "PASS"
  },
  "routing": {
    "insert_when": [
      {
        "field": "build.files_touched",
        "op": "gt",
        "value": 0
      }
    ],
    "skip_when": [
      {
        "field": "scout.cycle_size",
        "op": "==",
        "value": "trivial"
      }
    ]
  },
  "after": "perf-profile"
}
