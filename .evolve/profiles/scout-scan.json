{
  "name": "scout-scan",
  "role": "scout-scan",
  "cli": "claude-tmux",
  "model_tier_default": "balanced",
  "allowed_tools": [
    "Bash(evolve phase verify:*)",
    "Read",
    "Grep",
    "Glob",
    "Bash(git status)",
    "Bash(git status:*)",
    "Bash(git log:*)",
    "Bash(git diff:*)",
    "Bash(git show:*)",
    "Bash(git ls-files:*)",
    "Bash(git rev-parse:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(find:*)",
    "Bash(test:*)",
    "Write(.evolve/runs/cycle-*/workers/*)",
    "Write(.evolve/runs/cycle-*/scout-scan-*)",
    "Edit(.evolve/runs/cycle-*/workers/*)"
  ],
  "disallowed_tools": [
    "Agent",
    "Task",
    "WebSearch",
    "WebFetch",
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(git worktree:*)",
    "Bash(jq*)",
    "Bash(rm*)",
    "Bash(mv*)",
    "Bash(curl*)",
    "Bash(wget*)",
    "Bash(npm*)",
    "Bash(pip*)",
    "Bash(brew*)",
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)"
  ],
  "add_dir": ["."],
  "max_budget_usd": 0.25,
  "max_turns": 12,
  "turn_budget_hint": 6,
  "effort_level": "medium",
  "output_artifact": ".evolve/runs/cycle-{cycle}/workers/scout-scan-{slice}-digest.json",
  "challenge_token_required": true,
  "extra_flags_by_cli": {
    "claude-tmux": ["--strict-mcp-config", "--exclude-dynamic-system-prompt-sections", "--disable-slash-commands", "--setting-sources", "project"]
  },
  "sandbox": {
    "enabled": true,
    "write_subpaths": [".evolve/runs/cycle-*/workers"],
    "read_only_repo": false,
    "deny_subpaths": [".git", "scripts", "skills", "agents", ".claude-plugin", ".evolve/state.json", ".evolve/ledger.jsonl", ".evolve/profiles"],
    "allow_network": false
  },
  "parallel_eligible": true,
  "model_tier_envelope": {"min": "balanced", "default": "balanced", "max": "balanced"},
  "allowed_clis": ["all"],
  "stream_output": true,
  "generated_from": "hand-authored",
  "cli_fallback": ["claude-tmux"]
}
