{
  "name": "intent",
  "role": "intent",
  "cli": "claude",
  "model_tier_default": "opus",
  "model_tier_overrides": {
    "vague_goal": "opus",
    "clear_goal": "sonnet"
  },
  "_design_note_": "Opus default because intent capture is reasoning-heavy: surfacing the right premise to challenge from a vague goal is exactly the failure mode Karpathy named (#1: wrong assumptions running uncaught). Cheaper than burning $0.50+ on a Scout pointed at the wrong direction.",
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(find:*)",
    "Bash(test:*)",
    "Bash(git status:*)",
    "Bash(git log:*)",
    "Bash(git diff:*)",
    "Bash(git ls-files:*)",
    "Bash(git rev-parse:*)",
    "Write(.evolve/runs/cycle-*/intent.md)",
    "Write(.evolve/runs/cycle-*/intent-stdout.log)",
    "Edit(.evolve/runs/cycle-*/intent.md)"
  ],
  "disallowed_tools": [
    "WebSearch",
    "WebFetch",
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(git worktree:*)",
    "Bash(jq*)",
    "Bash(rm*)",
    "Bash(mv*)",
    "Bash(curl*)",
    "Bash(wget*)",
    "Bash(npm*)",
    "Bash(pip*)",
    "Bash(brew*)",
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Edit(.evolve/evals/**)",
    "Edit(CLAUDE.md)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(CLAUDE.md)"
  ],
  "_disallowed_design_note_": "WebSearch/WebFetch are explicitly denied — intent persona's job is to STRUCTURE, not RESEARCH. Scout researches. Otherwise mirrors scout.json's denylist verbatim per Plan-agent finding (intent persona must not become weakest-link attack surface).",
  "add_dir": [
    "."
  ],
  "max_budget_usd": 0.25,
  "_budget_design_note_": "Intent capture is one persona, one short artifact (50-200 lines), no web research. $0.25 is a hard cap — if you spend more, you are over-thinking. Compare scout default $0.50 (with research) and orchestrator $1.00 (full cycle).",
  "max_turns": 15,
  "permission_mode": "bypassPermissions",
  "output_artifact": ".evolve/runs/cycle-{cycle}/intent.md",
  "challenge_token_required": true,
  "extra_flags": [
    "--bare",
    "--no-session-persistence",
    "--strict-mcp-config",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": false,
    "deny_subpaths": [
      ".git",
      "scripts",
      "skills",
      "agents",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals"
    ],
    "allow_network": false
  },
  "_sandbox_design_note_": "allow_network: false because intent persona has no legitimate network reason. Scout has allow_network: true. Smaller blast radius if persona is hijacked."
}
