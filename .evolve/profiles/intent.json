{
  "name": "intent",
  "role": "intent",
  "cli": "claude",
  "model_tier_default": "opus",
  "model_tier_overrides": {
    "vague_goal": "opus",
    "clear_goal": "sonnet"
  },
  "allowed_tools": [
    "Read",
    "Bash(cat:*)",
    "Write(.evolve/runs/cycle-*/intent.md)",
    "Write(.evolve/runs/cycle-*/intent-stdout.log)",
    "Edit(.evolve/runs/cycle-*/intent.md)"
  ],
  "disallowed_tools": [
    "WebSearch",
    "WebFetch",
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(git worktree:*)",
    "Bash(jq*)",
    "Bash(rm*)",
    "Bash(mv*)",
    "Bash(curl*)",
    "Bash(wget*)",
    "Bash(npm*)",
    "Bash(pip*)",
    "Bash(brew*)",
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Edit(.evolve/evals/**)",
    "Edit(CLAUDE.md)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(CLAUDE.md)"
  ],
  "add_dir": [
    "."
  ],
  "max_budget_usd": 0.3,
  "budget_tiers": {
    "default": 0.3,
    "heavy_rules": 0.6,
    "minimal": 0.15
  },
  "max_turns": 4,
  "permission_mode": "bypassPermissions",
  "output_artifact": ".evolve/runs/cycle-{cycle}/intent.md",
  "challenge_token_required": true,
  "extra_flags": [
    "--bare",
    "--no-session-persistence",
    "--strict-mcp-config",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": false,
    "deny_subpaths": [
      ".git",
      "scripts",
      "skills",
      "agents",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals"
    ],
    "allow_network": false
  },
  "parallel_eligible": false
}
