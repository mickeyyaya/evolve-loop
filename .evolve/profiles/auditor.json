{
  "name": "auditor",
  "role": "auditor",
  "cli": "claude",
  "model_tier_default": "opus",
  "model_tier_overrides": {
    "security_sensitive": "opus",
    "clean_build": "opus"
  },
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Bash(git status:*)",
    "Bash(git log:*)",
    "Bash(git diff:*)",
    "Bash(git show:*)",
    "Bash(git ls-files:*)",
    "Bash(git rev-parse:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(find:*)",
    "Bash(test:*)",
    "Bash(diff:*)",
    "Bash(sha256sum:*)",
    "Bash(shasum:*)",
    "Bash(pytest:*)",
    "Bash(python -m pytest:*)",
    "Bash(npm test:*)",
    "Bash(npm run test:*)",
    "Bash(bash scripts/verify-eval.sh:*)",
    "Bash(bash scripts/cycle-health-check.sh:*)",
    "Bash(bash scripts/eval-quality-check.sh:*)",
    "Bash(bash scripts/guards-test.sh:*)",
    "Bash(bash scripts/ship-integration-test.sh:*)",
    "Bash(bash scripts/subagent-run-test.sh:*)",
    "Bash(bash scripts/merge-lesson-test.sh:*)",
    "Bash(bash scripts/release.sh:*)",
    "Bash(bash scripts/subagent-run.sh:*)",
    "Write(.evolve/runs/cycle-*/audit-report.md)",
    "Write(.evolve/runs/cycle-*/handoff-auditor.json)",
    "Write(.evolve/runs/cycle-*/auditor-stdout.log)",
    "Edit(.evolve/runs/cycle-*/audit-report.md)",
    "Edit(.evolve/runs/cycle-*/handoff-auditor.json)"
  ],
  "disallowed_tools": [
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Edit(.evolve/evals/**)",
    "Edit(CLAUDE.md)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(CLAUDE.md)",
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(jq -i:*)",
    "Bash(jq --in-place:*)",
    "Bash(rm*)",
    "Bash(mv*)"
  ],
  "add_dir": [
    "."
  ],
  "max_budget_usd": 2.5,
  "max_turns": 40,
  "permission_mode": "acceptEdits",
  "output_artifact": ".evolve/runs/cycle-{cycle}/audit-report.md",
  "challenge_token_required": true,
  "extra_flags": [
    "--bare",
    "--no-session-persistence",
    "--strict-mcp-config",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": true,
    "deny_subpaths": [
      ".git",
      "scripts",
      "skills",
      "agents",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals"
    ],
    "allow_network": true
  }
}
