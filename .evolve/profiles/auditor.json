{
  "name": "auditor",
  "role": "auditor",
  "cli": "claude",
  "model_tier_default": "opus",
  "model_tier_overrides": {
    "security_sensitive": "opus",
    "clean_build": "opus"
  },
  "allowed_tools": [
    "Bash(verify-eval.sh:*)",
    "Bash(cycle-health-check.sh:*)",
    "Bash(eval-quality-check.sh:*)",
    "Bash(guards-test.sh:*)",
    "Bash(ship-integration-test.sh:*)",
    "Bash(subagent-run-test.sh:*)",
    "Bash(merge-lesson-test.sh:*)",
    "Bash(role-gate-test.sh:*)",
    "Bash(phase-gate-precondition-test.sh:*)",
    "Bash(cycle-state.sh get:*)",
    "Bash(cycle-state.sh exists)",
    "Bash(cycle-state.sh exists:*)",
    "Bash(cycle-state.sh dump)",
    "Bash(cycle-state.sh dump:*)",
    "Bash(cycle-state.sh path)",
    "Bash(cycle-state.sh path:*)",
    "Bash(cycle-state.sh prune-expired-failures:*)",
    "Bash(run-cycle.sh:*)",
    "Bash(release-pipeline-test.sh:*)",
    "Bash(preflight-test.sh:*)",
    "Bash(changelog-gen-test.sh:*)",
    "Bash(marketplace-poll-test.sh:*)",
    "Bash(rollback-test.sh:*)",
    "Bash(release-pipeline.sh:*)",
    "Bash(preflight.sh:*)",
    "Bash(version-bump.sh:*)",
    "Bash(changelog-gen.sh:*)",
    "Bash(marketplace-poll.sh:*)",
    "Bash(rollback.sh:*)",
    "Bash(probe-tool.sh:*)",
    "Bash(probe-tool-test.sh:*)",
    "Bash(postedit-validate.sh:*)",
    "Bash(postedit-validate-test.sh:*)",
    "Bash(claude-adapter-test.sh:*)",
    "Bash(run-all-regression-tests.sh:*)",
    "Bash(run-all-regression-tests-test.sh:*)",
    "Bash(show-cycle-cost.sh:*)",
    "Bash(show-cycle-cost-test.sh:*)",
    "Bash(release.sh:*)",
    "Bash(subagent-run.sh:*)",
    "Read",
    "Grep",
    "Glob",
    "Bash(git status:*)",
    "Bash(git log:*)",
    "Bash(git diff:*)",
    "Bash(git show:*)",
    "Bash(git ls-files:*)",
    "Bash(git rev-parse:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(find:*)",
    "Bash(test:*)",
    "Bash(diff:*)",
    "Bash(sha256sum:*)",
    "Bash(shasum:*)",
    "Bash(pytest:*)",
    "Bash(python -m pytest:*)",
    "Bash(npm test:*)",
    "Bash(npm run test:*)",
    "Write(.evolve/runs/cycle-*/audit-report.md)",
    "Write(.evolve/runs/cycle-*/handoff-auditor.json)",
    "Write(.evolve/runs/cycle-*/auditor-stdout.log)",
    "Write(.evolve/runs/cycle-*/workers/*)",
    "Edit(.evolve/runs/cycle-*/audit-report.md)",
    "Edit(.evolve/runs/cycle-*/handoff-auditor.json)",
    "Edit(.evolve/runs/cycle-*/workers/*)"
  ],
  "disallowed_tools": [
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Edit(.evolve/evals/**)",
    "Edit(CLAUDE.md)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(CLAUDE.md)",
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(jq -i:*)",
    "Bash(jq --in-place:*)",
    "Bash(rm*)",
    "Bash(mv*)",
    "Bash(unlink:*)",
    "Bash(ln:*)",
    "Bash(cp:*)",
    "Bash(PATH=:*)",
    "Bash(export PATH:*)",
    "Bash(cycle-state.sh clear)",
    "Bash(cycle-state.sh clear:*)",
    "Bash(cycle-state.sh init:*)",
    "Bash(cycle-state.sh init)",
    "Bash(cycle-state.sh set-worktree:*)",
    "Bash(cycle-state.sh set-worktree)",
    "Bash(cycle-state.sh advance:*)",
    "Bash(cycle-state.sh set-agent:*)"
  ],
  "add_dir": [
    "."
  ],
  "max_budget_usd": 2.5,
  "max_turns": 40,
  "permission_mode": "bypassPermissions",
  "output_artifact": ".evolve/runs/cycle-{cycle}/audit-report.md",
  "challenge_token_required": true,
  "extra_flags": [
    "--bare",
    "--no-session-persistence",
    "--strict-mcp-config",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "parallel_subtasks": [
    {
      "name": "eval-replay",
      "prompt_template": "You are auditor-eval-replay for cycle {cycle}. Re-run every eval in .evolve/evals/cycle-*/ via scripts/verify-eval.sh and report PASS/FAIL per eval. The first content line of your report MUST be 'Verdict: PASS' (all evals pass) or 'Verdict: FAIL' (any eval fails). Body lists each eval and its outcome. DO NOT do lint or regression work \u2014 those are other workers."
    },
    {
      "name": "lint",
      "prompt_template": "You are auditor-lint for cycle {cycle}. Run static analysis on changed files since cycle start (git diff HEAD): shellcheck for .sh, jsonlint for .json, type-checks for any .py/.ts. First content line: 'Verdict: PASS' (no critical lint errors) or 'Verdict: FAIL'. Body lists findings with file:line. DO NOT run tests."
    },
    {
      "name": "regression",
      "prompt_template": "You are auditor-regression for cycle {cycle}. Run scripts/run-all-regression-tests.sh and parse the JSON output. First content line: 'Verdict: PASS' (zero failures) or 'Verdict: FAIL' (any failures, even pre-existing \u2014 Builder is responsible for not regressing further). Body summarizes total/passed/failed counts and lists any new failures vs. baseline."
    },
    {
      "name": "build-quality",
      "prompt_template": "You are auditor-build-quality for cycle {cycle}. Verify build artifacts and dependency hygiene: package-lock changes are intentional, no committed secrets, no unintended large files added. First content line: 'Verdict: PASS' or 'Verdict: WARN' (issues but not blocking) or 'Verdict: FAIL' (blocking)."
    }
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": true,
    "deny_subpaths": [
      ".git",
      "scripts",
      "skills",
      "agents",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals",
      "knowledge-base",
      "docs/private"
    ],
    "allow_network": true
  },
  "consensus": {
    "enabled": false,
    "_doc": "v8.54.0+: cross-CLI consensus auditing. When enabled (via EVOLVE_CONSENSUS_AUDIT=1 or --consensus-audit flag on dispatcher), the audit phase fans out across cli_voters[] and aggregates via aggregator.sh's cross-cli-vote merge mode (MAJORITY-PASS with FAIL-VETO). Defeats same-vendor sycophancy at the cost of N x audit budget. See docs/architecture/multi-llm-review.md for protocol details.",
    "cli_voters": [
      "claude",
      "gemini",
      "codex"
    ],
    "quorum": 2,
    "require_min_tier": "hybrid"
  },
  "parallel_eligible": true,
  "context_anchors": [
    "scout-report.md:proposed_tasks",
    "scout-report.md:acceptance_criteria",
    "build-report.md:diff_summary",
    "build-report.md:test_results"
  ]
}
