{
  "name": "secret-leak-scan",
  "role": "secret-leak-scan",
  "cli": "claude-tmux",
  "cli_fallback": [],
  "model_tier_default": "balanced",
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Bash",
    "Bash(evolve phase verify:*)"
  ],
  "disallowed_tools": [
    "Edit",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Bash(git push:*)",
    "Bash(git commit:*)",
    "Bash(git config:*)"
  ],
  "max_budget_usd": 0.4,
  "max_turns": 12,
  "output_artifact": "secret-leak-scan-report.md",
  "challenge_token_required": true,
  "extra_flags_by_cli": {
    "claude-tmux": [
      "--tools",
      "Bash",
      "Read",
      "Write",
      "Grep",
      "Glob",
      "--strict-mcp-config",
      "--exclude-dynamic-system-prompt-sections",
      "--disable-slash-commands",
      "--setting-sources",
      "project"
    ]
  },
  "parallel_eligible": false,
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": true,
    "deny_subpaths": [
      ".git",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals"
    ],
    "allow_network": false
  },
  "generated_from": "hand-authored"
}
