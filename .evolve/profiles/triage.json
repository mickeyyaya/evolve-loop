{
  "name": "triage",
  "role": "triage",
  "cli": "claude",
  "model_tier_default": "sonnet",
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Bash(git status:*)",
    "Bash(git status)",
    "Bash(git log:*)",
    "Bash(git diff:*)",
    "Bash(git show:*)",
    "Bash(git ls-files:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(find:*)",
    "Bash(test:*)",
    "Bash(jq:*)",
    "Write(.evolve/runs/cycle-*/triage-decision.md)",
    "Edit(.evolve/runs/cycle-*/triage-decision.md)",
    "Write(.evolve/runs/cycle-*/triage-decision.json)",
    "Edit(.evolve/runs/cycle-*/triage-decision.json)",
    "Bash(inbox-mover.sh:*)",
    "Bash(inbox-mover.sh claim:*)"
  ],
  "disallowed_tools": [
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(git worktree:*)",
    "Bash(gh:*)",
    "Bash(rm:*)",
    "Bash(mv:*)",
    "Bash(curl:*)",
    "Bash(wget:*)",
    "Bash(npm:*)",
    "Bash(pip:*)",
    "Bash(brew:*)",
    "WebFetch",
    "WebSearch",
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(CHANGELOG.md)",
    "Edit(README.md)",
    "Edit(CLAUDE.md)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Edit(.evolve/evals/**)",
    "Edit(.evolve/instincts/**)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(CHANGELOG.md)",
    "Write(README.md)",
    "Write(CLAUDE.md)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(.evolve/instincts/**)"
  ],
  "add_dir": [
    "."
  ],
  "max_budget_usd": 0.75,
  "max_turns": 15,
  "turn_budget_hint": 12,
  "permission_mode": "bypassPermissions",
  "output_artifact": ".evolve/runs/cycle-{cycle}/triage-decision.md",
  "challenge_token_required": true,
  "extra_flags": [
    "--bare",
    "--no-session-persistence",
    "--strict-mcp-config",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*",
      ".evolve/inbox/processing"
    ],
    "read_only_repo": true,
    "deny_subpaths": [
      ".git",
      "skills",
      "agents",
      "scripts",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals",
      ".evolve/instincts",
      "CHANGELOG.md",
      "README.md",
      "CLAUDE.md"
    ],
    "allow_network": false
  },
  "parallel_eligible": false,
  "context_anchors": [
    "scout-report.md:proposed_tasks"
  ]
}
