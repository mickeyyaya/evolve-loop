{
  "name": "spec-verifier",
  "role": "spec-verifier",
  "cli": "claude-tmux",
  "model_tier_default": "sonnet",
  "max_turns": 10,
  "output_artifact": ".evolve/runs/cycle-{cycle}/spec-verify-report.md",
  "challenge_token_required": true,
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": true
  },
  "generated_from": "hand-authored"
}
