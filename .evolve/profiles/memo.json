{
  "name": "memo",
  "role": "memo",
  "cli": "claude",
  "model_tier_default": "sonnet",
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(find:*)",
    "Bash(test:*)",
    "Bash(jq:*)",
    "Write(.evolve/runs/cycle-*/carryover-todos.json)",
    "Edit(.evolve/runs/cycle-*/carryover-todos.json)"
  ],
  "disallowed_tools": [
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(git worktree:*)",
    "Bash(gh:*)",
    "Bash(rm:*)",
    "Bash(mv:*)",
    "Bash(curl:*)",
    "Bash(wget:*)",
    "Bash(npm:*)",
    "Bash(pip:*)",
    "Bash(brew:*)",
    "WebFetch",
    "WebSearch",
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(CHANGELOG.md)",
    "Edit(README.md)",
    "Edit(CLAUDE.md)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Edit(.evolve/evals/**)",
    "Edit(.evolve/instincts/**)",
    "Edit(.evolve/runs/cycle-*/retrospective-report.md)",
    "Edit(.evolve/runs/cycle-*/lessons-digest.md)",
    "Edit(.evolve/runs/cycle-*/build-report.md)",
    "Edit(.evolve/runs/cycle-*/audit-report.md)",
    "Edit(.evolve/runs/cycle-*/scout-report.md)",
    "Edit(.evolve/runs/cycle-*/triage-decision.md)",
    "Edit(.evolve/runs/cycle-*/intent.md)",
    "Edit(.evolve/runs/cycle-*/orchestrator-report.md)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(CHANGELOG.md)",
    "Write(README.md)",
    "Write(CLAUDE.md)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(.evolve/instincts/**)",
    "Write(.evolve/runs/cycle-*/retrospective-report.md)",
    "Write(.evolve/runs/cycle-*/lessons-digest.md)",
    "Write(.evolve/runs/cycle-*/build-report.md)",
    "Write(.evolve/runs/cycle-*/audit-report.md)",
    "Write(.evolve/runs/cycle-*/scout-report.md)",
    "Write(.evolve/runs/cycle-*/triage-decision.md)",
    "Write(.evolve/runs/cycle-*/intent.md)",
    "Write(.evolve/runs/cycle-*/orchestrator-report.md)"
  ],
  "add_dir": ["."],
  "max_budget_usd": 0.30,
  "max_turns": 10,
  "permission_mode": "bypassPermissions",
  "output_artifact": ".evolve/runs/cycle-{cycle}/carryover-todos.json",
  "challenge_token_required": false,
  "extra_flags": [
    "--bare",
    "--no-session-persistence",
    "--strict-mcp-config",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [".evolve/runs/cycle-*"],
    "read_only_repo": true,
    "deny_subpaths": [
      ".git",
      "skills",
      "agents",
      "scripts",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals",
      ".evolve/instincts",
      "CHANGELOG.md",
      "README.md",
      "CLAUDE.md"
    ],
    "allow_network": false
  },
  "_design_notes": "v8.57.0 Layer P single-writer PASS-cycle memo. Fires only on PASS verdicts after ship.sh succeeds. Reads scout-report.md + triage-decision.md (if present); writes ONLY carryover-todos.json. Cheap (~$0.10-0.20 per cycle, max_budget_usd=0.30). Cannot mutate any other artifact, cannot write retrospective/digest (those are FAIL/WARN retrospective's job). parallel_eligible:false because carryover-todos.json is a single-writer artifact for this cycle. Challenge token NOT required because the artifact is a JSON array (machine-parsed, not LLM-judged) and forgery surface is small.",
  "parallel_eligible": false,
  "_parallel_eligible_reason": "Single-writer of carryover-todos.json on PASS path (sequential write discipline)"
}
