{
  "name": "builder",
  "role": "builder",
  "cli": "claude",
  "model_tier_default": "sonnet",
  "model_tier_overrides": {
    "ultrathink_strategy": "opus",
    "m_complex_5plus_files": "opus",
    "audit_retry_2plus": "opus",
    "s_complex_with_cache": "haiku"
  },
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Edit",
    "Write",
    "MultiEdit",
    "NotebookEdit",
    "Bash",
    "Skill(code-review-simplify)",
    "Skill(security-review-scored)",
    "WebSearch",
    "WebFetch",
    "Bash(scripts/research/kb-search.sh:*)"
  ],
  "disallowed_tools": [
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Bash(git push:*)",
    "Bash(git config:*)",
    "Bash(jq -i:*)",
    "Bash(jq --in-place:*)",
    "Bash(perl:*)",
    "Bash(perl -e:*)",
    "Bash(ruby:*)",
    "Bash(ruby -e:*)",
    "Bash(python3 -c:*)",
    "Bash(python -c:*)",
    "Bash(node -e:*)",
    "Bash(osascript:*)",
    "Bash(osascript -e:*)",
    "Bash(sh -c:*)",
    "Bash(bash -c:*)",
    "Bash(zsh -c:*)",
    "Bash(env:*)",
    "Bash(exec:*)",
    "Bash(eval:*)",
    "Bash(awk:*)",
    "Bash(unlink:*)",
    "Bash(ln:*)",
    "Edit(.evolve/runs/*/build-report.md:AC-TABLE)",
    "Write(.evolve/runs/*/build-report.md:AC-TABLE)",
    "Edit(acs/cycle-*/**)",
    "Edit(acs/cycle-*)",
    "Write(acs/cycle-*/**)",
    "Write(acs/cycle-*)",
    "Edit(acs/regression-suite/**)",
    "Write(acs/regression-suite/**)"
  ],
  "add_dir": [
    "{worktree_path}"
  ],
  "max_budget_usd": 1.0,
  "max_turns": 25,
  "turn_budget_hint": 20,
  "turn_budget_guidance": {
    "target_turns": 15,
    "checkpoint_at_turn": 15,
    "hard_exit_at_turn": 18,
    "checkpoint_note": "At turn 15: list remaining steps, estimate turns needed, defer anything that cannot fit in the remaining 10 turns. Never defer build-report.md write or worktree commit."
  },
  "effort_level": "medium",
  "permission_mode": "bypassPermissions",
  "output_artifact": ".evolve/runs/cycle-{cycle}/build-report.md",
  "challenge_token_required": true,
  "isolation": "worktree",
  "extra_flags": [
    "--no-session-persistence",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project",
    "--plugin-dir",
    ".evolve/plugin"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      "{worktree_path}",
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": false,
    "deny_subpaths": [
      ".git",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals"
    ],
    "allow_network": true
  },
  "parallel_eligible": false,
  "context_clear_trigger_tokens": 30000,
  "context_anchors": [
    "scout-report.md:proposed_tasks",
    "scout-report.md:acceptance_criteria"
  ],
  "model_tier_envelope": {
    "min": "balanced",
    "default": "balanced",
    "max": "deep"
  },
  "cross_family_with": "auditor",
  "allowed_clis": [
    "claude"
  ],
  "_note": "Restricted to claude until Phase 4 — Gemini/Codex/Grok adapters need sandbox + permission scoping + budget cap parity. Builder is safety-critical (writes code in worktree).",
  "research_quota": {
    "web_search": 3,
    "web_fetch": 5,
    "kb_search": 20
  }
}
