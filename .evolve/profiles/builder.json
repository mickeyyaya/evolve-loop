{
  "name": "builder",
  "role": "builder",
  "cli": "claude",
  "model_tier_default": "sonnet",
  "model_tier_overrides": {
    "ultrathink_strategy": "opus",
    "m_complex_5plus_files": "opus",
    "audit_retry_2plus": "opus",
    "s_complex_with_cache": "haiku"
  },
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Edit",
    "Write",
    "MultiEdit",
    "NotebookEdit",
    "Bash"
  ],
  "disallowed_tools": [
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Bash(git push:*)",
    "Bash(git config:*)",
    "Bash(jq -i:*)",
    "Bash(jq --in-place:*)",
    "Bash(perl:*)",
    "Bash(perl -e:*)",
    "Bash(ruby:*)",
    "Bash(ruby -e:*)",
    "Bash(python3 -c:*)",
    "Bash(python -c:*)",
    "Bash(node -e:*)",
    "Bash(osascript:*)",
    "Bash(osascript -e:*)",
    "Bash(sh -c:*)",
    "Bash(bash -c:*)",
    "Bash(zsh -c:*)",
    "Bash(env:*)",
    "Bash(exec:*)",
    "Bash(eval:*)",
    "Bash(awk:*)",
    "Bash(unlink:*)",
    "Bash(ln:*)"
  ],
  "add_dir": [
    "{worktree_path}"
  ],
  "max_budget_usd": 1.0,
  "max_turns": 25,
  "_v9_0_4_design_note_": "Lowered max_budget_usd 2.5 → 1.0 and max_turns 80 → 25 after cycle-11 evidence (58 turns / $1.95). Design target is 15-20 turns; 25 leaves headroom for the legitimate cases where a build needs an extra retry. Tool surface is unchanged — builder genuinely needs Read/Grep/Glob/Edit/Write/MultiEdit/NotebookEdit/Bash to do its work. Turn count is bounded by persona-side ## Turn budget section + per-step turn caps in Workflow.",
  "permission_mode": "bypassPermissions",
  "output_artifact": ".evolve/runs/cycle-{cycle}/build-report.md",
  "challenge_token_required": true,
  "isolation": "worktree",
  "extra_flags": [
    "--no-session-persistence",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      "{worktree_path}",
      ".evolve/runs/cycle-*"
    ],
    "read_only_repo": false,
    "deny_subpaths": [
      ".git",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals"
    ],
    "allow_network": true
  },
  "parallel_eligible": false,
  "_parallel_eligible_reason": "Single-writer invariant on worktree"
}
