    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(.evolve/instincts/**)",
    "Write(.evolve/runs/cycle-*/retrospective-report.md)",
    "Write(.evolve/runs/cycle-*/lessons-digest.md)",
    "Write(.evolve/runs/cycle-*/memo.md)",
    "Write(.evolve/runs/cycle-*/build-report.md)",
