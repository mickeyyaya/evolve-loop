{
  "_comment": "Reflector — runs every cycle in the formalized Learn phase (v10.20.0+). Reads per-phase <phase>-reflection.yaml sidecars, calls aggregate-reflections.sh for cross-cycle rollup, emits learn/reflector-synthesis.md. Strict read-only-repo per single-writer invariant; writes confined to .evolve/runs/cycle-*/learn/. Lightweight cost target (~$0.05–0.15/cycle), modelled on memo.json.",
  "name": "reflector",
  "role": "reflector",
  "cli": "agy-tmux",
  "model_tier_default": "fast",
  "allowed_tools": [
