{
  "name": "retrospective",
  "role": "retrospective",
  "cli": "claude",
  "model_tier_default": "sonnet",
  "model_tier_overrides": {
    "systemic_failure": "opus",
    "first_observation": "sonnet"
  },
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Bash(git status:*)",
    "Bash(git status)",
    "Bash(git log:*)",
    "Bash(git diff:*)",
    "Bash(git show:*)",
    "Bash(git ls-files:*)",
    "Bash(git rev-parse:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(find:*)",
    "Bash(test:*)",
    "Bash(diff:*)",
    "Bash(sha256sum:*)",
    "Bash(shasum:*)",
    "Bash(jq:*)",
    "Write(.evolve/runs/cycle-*/retrospective-report.md)",
    "Write(.evolve/runs/cycle-*/handoff-retrospective.json)",
    "Write(.evolve/instincts/lessons/*.yaml)",
    "Edit(.evolve/runs/cycle-*/retrospective-report.md)",
    "Edit(.evolve/runs/cycle-*/handoff-retrospective.json)",
    "Edit(.evolve/instincts/lessons/*.yaml)"
  ],
  "disallowed_tools": [
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git reset:*)",
    "Bash(git checkout:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(git worktree:*)",
    "Bash(gh release:*)",
    "Bash(gh pr:*)",
    "Bash(rm:*)",
    "Bash(mv:*)",
    "Bash(curl:*)",
    "Bash(wget:*)",
    "Bash(npm:*)",
    "Bash(pip:*)",
    "Bash(brew:*)",
    "Bash(jq -i:*)",
    "Bash(jq --in-place:*)",
    "WebFetch",
    "WebSearch",
    "Edit(skills/**)",
    "Edit(agents/**)",
    "Edit(scripts/**)",
    "Edit(.claude-plugin/**)",
    "Edit(CHANGELOG.md)",
    "Edit(README.md)",
    "Edit(CLAUDE.md)",
    "Edit(.evolve/state.json)",
    "Edit(.evolve/ledger.jsonl)",
    "Edit(.evolve/profiles/**)",
    "Edit(.evolve/evals/**)",
    "Edit(.evolve/instincts/personal/**)",
    "Edit(.evolve/instincts/archived/**)",
    "Write(skills/**)",
    "Write(agents/**)",
    "Write(scripts/**)",
    "Write(.claude-plugin/**)",
    "Write(CHANGELOG.md)",
    "Write(README.md)",
    "Write(CLAUDE.md)",
    "Write(.evolve/state.json)",
    "Write(.evolve/ledger.jsonl)",
    "Write(.evolve/profiles/**)",
    "Write(.evolve/evals/**)",
    "Write(.evolve/instincts/personal/**)",
    "Write(.evolve/instincts/archived/**)"
  ],
  "add_dir": [
    "."
  ],
  "max_budget_usd": 1.5,
  "max_turns": 30,
  "permission_mode": "acceptEdits",
  "output_artifact": ".evolve/runs/cycle-{cycle}/retrospective-report.md",
  "challenge_token_required": true,
  "extra_flags": [
    "--bare",
    "--no-session-persistence",
    "--strict-mcp-config",
    "--exclude-dynamic-system-prompt-sections",
    "--disable-slash-commands",
    "--setting-sources",
    "project"
  ],
  "sandbox": {
    "enabled": true,
    "write_subpaths": [
      ".evolve/runs/cycle-*",
      ".evolve/instincts/lessons"
    ],
    "read_only_repo": true,
    "deny_subpaths": [
      ".git",
      "skills",
      "agents",
      "scripts",
      ".claude-plugin",
      ".evolve/state.json",
      ".evolve/ledger.jsonl",
      ".evolve/profiles",
      ".evolve/evals",
      ".evolve/instincts/personal",
      ".evolve/instincts/archived",
      "CHANGELOG.md",
      "README.md",
      "CLAUDE.md"
    ],
    "allow_network": false
  },
  "_design_notes": "The retrospective subagent is invoked ONLY on cycle FAIL/WARN/SHIP_GATE_DENIED. Read-only across the repo, write-only within .evolve/runs/cycle-*/retrospective-* and .evolve/instincts/lessons/*.yaml. Network is disabled \u2014 retrospectives must work from on-disk artifacts, not reach out for fresh context. Cannot mutate existing personal instincts (only the orchestrator's downstream prune step can do that, based on the contradicts: field in the lesson YAML). See agents/evolve-retrospective.md for the operational contract and skills/evolve-loop/phase6-learn.md for the orchestrator's invocation pattern."
}
