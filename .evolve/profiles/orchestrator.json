{
  "name": "orchestrator",
  "role": "orchestrator",
  "cli": "claude",
  "model_tier_default": "sonnet",
  "model_tier_overrides": {
    "cycle_1_or_low_goal": "opus",
    "cycle_4_plus_mature": "haiku"
  },
  "_design_notes": "v8.13.1 orchestrator subagent profile. The orchestrator subagent is spawned by scripts/run-cycle.sh and constrained by three PreToolUse hooks (ship-gate, phase-gate-precondition, role-gate). allowed_tools is intentionally narrow: orchestrator can RUN scripts (via Bash(bash scripts/...:*)) but cannot Edit/Write source code (that's Builder's job inside a worktree — role-gate enforces) and cannot directly invoke git commit/push/gh release create (must go through scripts/ship.sh which ship-gate allowlists). Phase ordering is enforced by phase-gate-precondition: subagent-run.sh invocations must respect the Scout→Builder→Auditor sequence in cycle-state.json. v8.13.1 audit MEDIUM-1 fix: cycle-state.sh permissions are restricted to {advance,set-agent,get,exists,dump,path} subcommands; init+clear are denied so the orchestrator cannot self-disable the gates by removing cycle-state.json. run-cycle.sh's parent process (NOT the orchestrator subagent) handles init/clear lifecycle.",
  "allowed_tools": [
    "Read",
    "Grep",
    "Glob",
    "Bash(bash scripts/ship.sh:*)",
    "Bash(bash scripts/subagent-run.sh:*)",
    "Bash(bash scripts/phase-gate.sh:*)",
    "Bash(bash scripts/release.sh:*)",
    "Bash(bash scripts/eval-quality-check.sh:*)",
    "Bash(bash scripts/mutate-eval.sh:*)",
    "Bash(bash scripts/cycle-health-check.sh:*)",
    "Bash(bash scripts/verify-eval.sh:*)",
    "Bash(bash scripts/record-failure-to-state.sh:*)",
    "Bash(bash scripts/cycle-state.sh advance:*)",
    "Bash(bash scripts/cycle-state.sh set-agent:*)",
    "Bash(bash scripts/cycle-state.sh get:*)",
    "Bash(bash scripts/cycle-state.sh exists:*)",
    "Bash(bash scripts/cycle-state.sh exists)",
    "Bash(bash scripts/cycle-state.sh dump:*)",
    "Bash(bash scripts/cycle-state.sh dump)",
    "Bash(bash scripts/cycle-state.sh path:*)",
    "Bash(bash scripts/cycle-state.sh path)",
    "Bash(bash scripts/run-cycle.sh:*)",
    "Bash(bash scripts/release-pipeline.sh:*)",
    "Bash(bash scripts/release/preflight.sh:*)",
    "Bash(bash scripts/release/version-bump.sh:*)",
    "Bash(bash scripts/release/changelog-gen.sh:*)",
    "Bash(bash scripts/release/marketplace-poll.sh:*)",
    "Bash(bash scripts/release/rollback.sh:*)",
    "Bash(scripts/guards-test.sh:*)",
    "Bash(scripts/subagent-run-test.sh:*)",
    "Bash(scripts/ship-integration-test.sh:*)",
    "Bash(git status)",
    "Bash(git status:*)",
    "Bash(git log:*)",
    "Bash(git diff:*)",
    "Bash(git show:*)",
    "Bash(git ls-files:*)",
    "Bash(git rev-parse:*)",
    "Bash(git branch:*)",
    "Bash(git stash list:*)",
    "Bash(git worktree list:*)",
    "Bash(jq:*)",
    "Bash(sha256sum:*)",
    "Bash(shasum:*)",
