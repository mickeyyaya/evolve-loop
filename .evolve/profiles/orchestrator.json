      ".evolve/release-journal",
      ".evolve/worktrees",
      ".evolve/environment.json",
      "CHANGELOG.md",
      "README.md",
      "CLAUDE.md",
      ".evolve/ledger.tip",
      "docs/private"
    ],
    "allow_network": true
  },
  "parallel_eligible": false
