      ".evolve/genes",
      ".evolve/tools",
      ".evolve/skill-inventory.json",
      ".evolve/token-baseline.json",
      ".evolve/domain.json",
      ".evolve/latest-brief.json",
      ".evolve/notes.md",
      ".evolve/guards.log",
      ".evolve/current_run_id",
