{
  "schema_version": 4,
  "_note": "v1: data-only registry consumed by list-phase-order.sh + orchestrator (cycle-57). v3: + top-level config{} block for dynamic phase routing (config.Load is the sole consumer); + per-phase enabled/routing (Specification triggers). v2 was never released — version jumped 1→3 to align with the dynamic-routing plan's schema number. dynamic_routing=0 ⇒ Stage:Off ⇒ static state machine drives, byte-identical to pre-routing behavior (the operator escape hatch). As of 2026-06-06 the default in the config block below is advisory.",
  "_v4_note": "v4 (user-definable phases / 'Lego pipeline'): the phasespec.PhaseSpec parser reads the FULL phase entry, accepting additive optional fields — kind (llm|native|command), agent, model, writes_source, inputs.signals/outputs.signals (the typed signal contract), prompt_context, classify (declarative verdict rules), gates.in/out, on_pass/on_fail. All optional and back-compat: omitted fields default (kind→llm, agent→evolve-<name>, model→auto). config.Load still reads only its routing subset and ignores the rest. User phases merge from .evolve/phases/<name>/phase.json over this built-in array (built-ins win on name clash).",
  "config": {
    "dynamic_routing": "advisory",
    "routing_mode": "llm",
    "mandatory_phases": ["scout", "triage", "build", "audit", "ship"],
    "conditional_mandatory": { "tdd": "cycle_size!=trivial" },
    "max_optional_insertions": 6,
    "_goal_recipes_note": "ADR-0052 WS5 recipe SSOT. Single source for the goal-type → optional-insertion recipe. Each value is the ordered, VERBATIM token list obtained by splitting the persona's recipe cell on ' → '; tokens are opaque (may contain spaces, '+', '=', '[..]' bracket markers). config.Load projects this into RoutingConfig.GoalRecipes; router.RenderRecipeProjection regenerates the agents/evolve-router.md '## Goal-Type Recipes' table body (locked by TestRouterPersonaRecipeTable_NoDrift) and the RecipeVerifier reads the same source — ending three-source recipe drift.",
    "goal_recipes": {
      "bugfix": ["premise-challenge", "fault-localization", "bug-reproduction", "[tdd, build]", "error-handling-scan", "coverage-gate", "flake-rerun-scan"],
      "feature": ["premise-challenge", "spec-verify", "api-contract-design", "[tdd, build]", "test-amplification", "coverage-gate", "secret-leak-scan"],
      "refactor": ["smell-scan", "behavior-baseline", "[build]", "behavior-compare", "type-safety-audit", "mutation-gate", "coverage-gate", "cleanup-sweep"],
      "security": ["threat-model", "[tdd, build]", "security-scan + dependency-audit", "authz-gap-scan", "secret-leak-scan", "fuzz-probe"],
      "performance": ["benchmark baseline capture", "[build]", "benchmark-gate"],
      "release": ["rollout-plan", "rollback-plan", "changelog-sync", "[ship]", "post-ship-monitor"],
      "docs / trivial": ["spine only (no insertions)"],
      "concurrency": ["[tdd, build]", "race-condition-scan", "flake-rerun-scan", "adversarial-review"],
      "api-design": ["api-contract-design", "[tdd, build]", "compat-surface-check", "contract-fuzz-probe"],
      "data-migration": ["rollback-plan", "[tdd, build]", "migration-safety-check", "coverage-gate"],
      "observability": ["observability-design", "[build]", "telemetry-coverage-check", "adversarial-review"],
      "supply-chain": ["[build]", "dependency-audit", "license-provenance-audit", "secret-leak-scan"],
      "agent-instruction": ["premise-challenge", "[build]", "prompt-regression-eval", "adversarial-review"],
      "accessibility": ["scope-baseline", "[build]", "accessibility-audit", "adversarial-review"],
      "frontend-ui": ["prd-draft", "[build]", "frontend-design-review", "accessibility-audit"],
      "i18n": ["scope-baseline", "[build]", "locale-format-check"],
      "database": ["data-model-design", "[tdd, build]", "query-performance-scan", "migration-safety-check"],
      "caching": ["caching-strategy-design", "[build]", "cache-strategy-scan"],
      "resilience": ["resilience-design", "[tdd, build]", "resilience-gap-scan", "flake-rerun-scan"],
      "messaging": ["[tdd, build]", "idempotency-check", "contract-fuzz-probe"],
      "infrastructure": ["[build]", "container-hardening-scan", "cicd-pipeline-audit", "secret-leak-scan"],
      "data-pipeline": ["scope-baseline", "[build]", "data-integrity-check", "migration-safety-check"],
      "project-management": ["risk-register", "scope-baseline", "dependency-map", "[build = the planning deliverable]"],
      "business-strategy": ["forces-analysis", "market-sizing", "okr-draft", "[build]"],
      "accounting-close": ["account-reconcile", "variance-analysis", "close-checklist", "[build]"],
      "product-discovery": ["opportunity-map", "prd-draft", "metric-tree", "[build]"],
      "ops-incident": ["incident-postmortem", "runbook-draft", "capacity-plan", "[build]"]
    }
  },
  "phases": [
    {
      "name": "intent",
      "role": "intent",
      "optional": true,
      "enable_var": "workflow.phase_enables.intent=on",
      "inputs": {
        "files": [],
        "state_fields": ["lastCycleNumber"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/intent.md"]
      },
      "gate_in": "gate_calibrate_to_intent",
      "gate_out": "gate_intent_to_discover",
      "parallel_eligible": false,
      "skippable_when_present": true
    },
    {
      "name": "scout",
      "role": "scout",
      "optional": false,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/intent.md"],
        "state_fields": ["instinctSummary", "ledgerSummary", "carryoverTodos"]
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/handoff-scout.json"
        ]
      },
      "gate_in": "gate_intent_to_discover",
      "gate_out": "gate_discover_to_triage",
      "routing": {
        "rubric_hint": [
          "scout.carryover_count >= 3 → skip scout (work already queued)",
          "scout.item_count == 0 → end cycle early (no-ship is legitimate)"
        ]
      },
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "triage",
      "role": "triage",
      "optional": true,
      "enable_var": "workflow.phase_enables.triage",
      "enabled": "on",
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
        "state_fields": ["carryoverTodos"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/triage-report.md"]
      },
      "gate_in": "gate_discover_to_triage",
      "gate_out": "gate_triage_to_plan_review",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "spec-verify",
      "role": "spec-verifier",
      "optional": true,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/spec-verify-report.md"]
      },
      "gate_in": "gate_triage_to_plan_review",
      "gate_out": "gate_plan_review_to_tdd",
      "parallel_eligible": false,
      "skippable_when_present": false
    },

    {
      "name": "architecture-design",
      "role": "architecture-design",
      "archetype": "plan",
      "optional": true,
      "enable_var": null,
      "enabled": "content",
      "kind": "llm",
      "model": "opus",
      "agent": "evolve-architecture-design",
      "writes_source": false,
      "routing": {
        "insert_when": [
          { "field": "scout.cycle_size", "op": "==", "value": "large" }
        ],
        "rubric_hint": [
          "a novel/cross-cutting goal also warrants architecture-design (a design pass before tdd/build)"
        ]
      },
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/architecture-design.md"]
      },
      "classify": {
        "require_sections": ["## Design", "## Decision", "## Blueprint"],
        "fail_if_empty": true,
        "verdict_on_pass": "PASS"
      },
      "_note": "WS3 free-topology: a Plan-archetype design pass the advisor SELECTS (catalog card) or that auto-inserts on a large-cycle scout signal. Reads scout's task, produces a trade-off-driven architecture-design.md; never writes source. Runner wired by registerBuiltinSpecRunners (specrunner fallback) since the persona evolve-architecture-design.md exists.",
      "parallel_eligible": false,
      "skippable_when_present": true
    },
    {
      "name": "plan-review",
      "role": "plan-reviewer",
      "agent": "plan-reviewer",
      "optional": true,
      "enable_var": "workflow.phase_enables.plan-review=on",
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/triage-report.md"
        ],
        "state_fields": ["instinctSummary"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/plan-review-report.md"]
      },
      "gate_in": "gate_triage_to_plan_review",
      "gate_out": "gate_plan_review_to_tdd",
      "routing": {
        "rubric_hint": [
          "build.files_touched >= 10 OR build.diff_loc >= 500 → insert plan-review"
        ],
        "_note": "Deliberately prose-only: plan-review PRECEDES build in canonical order, so build.* signals cannot drive an insert_when mid-walk — the hint guides the advisor's whole-cycle/next-cycle judgment. This hint is the thresholds' ONE home; if an insert_when is ever added, drop the hint (the rubric derives insert lines from structured triggers)."
      },
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "tdd",
      "role": "tdd-engineer",
      "optional": true,
      "enable_var": "workflow.phase_enables.tdd=on",
      "enabled": "on",
      "_v3_note": "enable_var migrated from EVOLVE_TEST_PHASE_ENABLED (cycle-39 flag-reduction). tdd is conditional-mandatory (cycle_size!=trivial) in config.conditional_mandatory; enabled:on is the legacy floor honored in Stage:Off.",
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/plan-review-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/tdd-contract.md"]
      },
      "gate_in": "gate_plan_review_to_tdd",
      "gate_out": "gate_tdd_to_build_planner",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "build-planner",
      "role": "build-planner",
      "optional": true,
      "enable_var": "workflow.phase_enables.build-planner=on",
      "enabled": "off",
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/test-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/build-plan.md"]
      },
      "gate_in": "gate_tdd_to_build_planner",
      "gate_out": "gate_build_planner_to_build",
      "_note": "Opt C cycle-103 (shadow). EVOLVE_BUILD_PLANNER=0 default — no persona runs until cycle-104.",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "build",
      "role": "builder",
      "optional": false,
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/triage-report.md"
        ],
        "state_fields": ["instinctSummary", "failedApproaches"]
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/build-report.md",
          ".evolve/runs/cycle-{cycle}/handoff-build.json"
        ]
      },
      "gate_in": "gate_build_planner_to_build",
      "gate_out": "gate_build_to_audit",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "doc-sync",
      "role": "doc-sync",
      "optional": true,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/build-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/doc-sync-report.md"]
      },
      "gate_in": "gate_build_to_audit",
      "gate_out": "gate_audit_to_ship",
      "parallel_eligible": false,
      "skippable_when_present": false
    },

    {
      "name": "tester",
      "role": "tester",
      "optional": true,
      "enable_var": null,
      "enabled": "content",
      "routing": {
        "insert_when": [
          { "field": "build.acs_red", "op": "gt", "value": 0 },
          { "field": "build.severity_max", "op": "gte", "value": "HIGH" }
        ]
      },
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/build-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/tester-report.md"]
      },
      "gate_in": "gate_build_to_tester",
      "gate_out": "gate_tester_to_audit",
      "_v1_note": "Tester gate functions wired in cycle 57 (gate_build_to_tester + gate_tester_to_audit). Predicate 020 validates gate refs resolve to declared functions.",
      "_v3_note": "routing.insert_when: a content-routed tester is proposed when the build's objective signals show failing predicates (acs_red>0) or a HIGH+ severity thrust. Honored only at Stage>=Advisory; in Shadow it is forensic-only.",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "audit",
      "role": "auditor",
      "optional": false,
      "on_pass": "ship",
      "on_fail": "retrospective",
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/build-report.md",
          ".evolve/runs/cycle-{cycle}/tester-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/audit-report.md",
          ".evolve/runs/cycle-{cycle}/acs-verdict.json"
        ]
      },
      "gate_in": "gate_build_to_audit",
      "gate_out": "gate_audit_to_ship",
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "ship",
      "role": "orchestrator",
      "kind": "native",
      "optional": false,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/audit-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": []
      },
      "gate_in": "gate_audit_to_ship",
      "gate_out": "gate_ship_to_learn",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "retrospective",
      "role": "retrospective",
      "optional": true,
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/audit-report.md",
          ".evolve/runs/cycle-{cycle}/build-report.md"
        ],
        "state_fields": ["failedApproaches"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/retrospective-report.md"]
      },
      "gate_in": "gate_audit_to_retrospective",
      "gate_out": "gate_retrospective_to_complete",
      "routing": {
        "rubric_hint": [
          "audit.verdict == FAIL OR audit.confidence < 0.85 → insert retrospective"
        ]
      },
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "memo",
      "role": "memo",
      "optional": true,
      "enable_var": null,
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/audit-report.md",
          ".evolve/runs/cycle-{cycle}/build-report.md",
          ".evolve/runs/cycle-{cycle}/scout-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/memo.md",
          ".evolve/runs/cycle-{cycle}/carryover-todos.json"
        ]
      },
      "gate_in": "gate_ship_to_learn",
      "gate_out": "gate_cycle_complete",
      "parallel_eligible": false,
      "skippable_when_present": false
    }
  ]
}
