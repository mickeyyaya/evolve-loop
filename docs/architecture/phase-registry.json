{
  "schema_version": 4,
  "_note": "v1: data-only registry consumed by list-phase-order.sh + orchestrator (cycle-57). v3: + top-level config{} block for dynamic phase routing (config.Load is the sole consumer); + per-phase enabled/routing (Specification triggers). v2 was never released — version jumped 1→3 to align with the dynamic-routing plan's schema number. dynamic_routing=0 ⇒ Stage:Off ⇒ static state machine drives, byte-identical to pre-routing behavior.",
  "_v4_note": "v4 (user-definable phases / 'Lego pipeline'): the phasespec.PhaseSpec parser reads the FULL phase entry, accepting additive optional fields — kind (llm|native|command), agent, model, writes_source, inputs.signals/outputs.signals (the typed signal contract), prompt_context, classify (declarative verdict rules), gates.in/out, on_pass/on_fail. All optional and back-compat: omitted fields default (kind→llm, agent→evolve-<name>, model→auto). config.Load still reads only its routing subset and ignores the rest. User phases merge from .evolve/phases/<name>/phase.json over this built-in array (built-ins win on name clash).",
  "config": {
    "dynamic_routing": "0",
    "routing_mode": "llm",
    "mandatory_phases": ["scout", "build", "audit", "ship"],
    "conditional_mandatory": { "tdd": "cycle_size!=trivial" },
    "max_optional_insertions": 6
  },
  "phases": [
    {
      "name": "intent",
      "role": "intent",
      "optional": true,
      "enable_var": "EVOLVE_REQUIRE_INTENT",
      "inputs": {
        "files": [],
        "state_fields": ["lastCycleNumber"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/intent.md"]
      },
      "gate_in": "gate_calibrate_to_intent",
      "gate_out": "gate_intent_to_discover",
      "parallel_eligible": false,
      "skippable_when_present": true
    },
    {
      "name": "scout",
      "role": "scout",
      "optional": false,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/intent.md"],
        "state_fields": ["instinctSummary", "ledgerSummary", "carryoverTodos"]
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/handoff-scout.json"
        ]
      },
      "gate_in": "gate_intent_to_discover",
      "gate_out": "gate_discover_to_triage",
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "triage",
      "role": "triage",
      "optional": true,
      "enable_var": "EVOLVE_TRIAGE_DISABLE",
      "enable_var_inverted": true,
      "enabled": "on",
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
        "state_fields": ["carryoverTodos"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/triage-decision.md"]
      },
      "gate_in": "gate_discover_to_triage",
      "gate_out": "gate_triage_to_plan_review",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "spec-verify",
      "role": "spec-verifier",
      "optional": true,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/spec-verify-report.md"]
      },
      "gate_in": "gate_triage_to_plan_review",
      "gate_out": "gate_plan_review_to_tdd",
      "parallel_eligible": false,
      "skippable_when_present": false
    },

    {
      "name": "architecture-design",
      "role": "architecture-design",
      "archetype": "plan",
      "optional": true,
      "enable_var": null,
      "enabled": "content",
      "kind": "llm",
      "model": "opus",
      "agent": "evolve-architecture-design",
      "writes_source": false,
      "routing": {
        "insert_when": [
          { "field": "scout.cycle_size", "op": "==", "value": "large" }
        ]
      },
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/scout-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/architecture-design.md"]
      },
      "classify": {
        "require_sections": ["## Design", "## Decision", "## Blueprint"],
        "fail_if_empty": true,
        "verdict_on_pass": "PASS"
      },
      "_note": "WS3 free-topology: a Plan-archetype design pass the advisor SELECTS (catalog card) or that auto-inserts on a large-cycle scout signal. Reads scout's task, produces a trade-off-driven architecture-design.md; never writes source. Runner wired by registerBuiltinSpecRunners (specrunner fallback) since the persona evolve-architecture-design.md exists.",
      "parallel_eligible": false,
      "skippable_when_present": true
    },
    {
      "name": "plan-review",
      "role": "plan-reviewer",
      "agent": "plan-reviewer",
      "optional": true,
      "enable_var": "EVOLVE_PLAN_REVIEW",
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/triage-decision.md"
        ],
        "state_fields": ["instinctSummary"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/plan-review-report.md"]
      },
      "gate_in": "gate_triage_to_plan_review",
      "gate_out": "gate_plan_review_to_tdd",
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "tdd",
      "role": "tdd-engineer",
      "optional": true,
      "enable_var": "EVOLVE_TEST_PHASE_ENABLED",
      "enabled": "on",
      "_v3_note": "enable_var corrected EVOLVE_TDD_PHASE -> EVOLVE_TEST_PHASE_ENABLED (the flag the tdd phase actually reads). tdd is conditional-mandatory (cycle_size!=trivial) in config.conditional_mandatory; enabled:on is the legacy floor honored in Stage:Off.",
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/plan-review-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/tdd-contract.md"]
      },
      "gate_in": "gate_plan_review_to_tdd",
      "gate_out": "gate_tdd_to_build_planner",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "build-planner",
      "role": "build-planner",
      "optional": true,
      "enable_var": "EVOLVE_BUILD_PLANNER",
      "enabled": "off",
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/test-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/build-plan.md"]
      },
      "gate_in": "gate_tdd_to_build_planner",
      "gate_out": "gate_build_planner_to_build",
      "_note": "Opt C cycle-103 (shadow). EVOLVE_BUILD_PLANNER=0 default — no persona runs until cycle-104.",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "build",
      "role": "builder",
      "optional": false,
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/scout-report.md",
          ".evolve/runs/cycle-{cycle}/triage-decision.md"
        ],
        "state_fields": ["instinctSummary", "failedApproaches"]
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/build-report.md",
          ".evolve/runs/cycle-{cycle}/handoff-build.json"
        ]
      },
      "gate_in": "gate_build_planner_to_build",
      "gate_out": "gate_build_to_audit",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "doc-sync",
      "role": "doc-sync",
      "optional": true,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/build-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/doc-sync-report.md"]
      },
      "gate_in": "gate_build_to_audit",
      "gate_out": "gate_audit_to_ship",
      "parallel_eligible": false,
      "skippable_when_present": false
    },

    {
      "name": "tester",
      "role": "tester",
      "optional": true,
      "enable_var": null,
      "enabled": "content",
      "routing": {
        "insert_when": [
          { "field": "build.acs_red", "op": "gt", "value": 0 },
          { "field": "build.severity_max", "op": "gte", "value": "HIGH" }
        ]
      },
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/build-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/tester-report.md"]
      },
      "gate_in": "gate_build_to_tester",
      "gate_out": "gate_tester_to_audit",
      "_v1_note": "Tester gate functions wired in cycle 57 (gate_build_to_tester + gate_tester_to_audit). Predicate 020 validates gate refs resolve to declared functions.",
      "_v3_note": "routing.insert_when: a content-routed tester is proposed when the build's objective signals show failing predicates (acs_red>0) or a HIGH+ severity thrust. Honored only at Stage>=Advisory; in Shadow it is forensic-only.",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "audit",
      "role": "auditor",
      "optional": false,
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/build-report.md",
          ".evolve/runs/cycle-{cycle}/tester-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/audit-report.md",
          ".evolve/runs/cycle-{cycle}/acs-verdict.json"
        ]
      },
      "gate_in": "gate_build_to_audit",
      "gate_out": "gate_audit_to_ship",
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "ship",
      "role": "orchestrator",
      "optional": false,
      "inputs": {
        "files": [".evolve/runs/cycle-{cycle}/audit-report.md"],
        "state_fields": []
      },
      "outputs": {
        "files": []
      },
      "gate_in": "gate_audit_to_ship",
      "gate_out": "gate_ship_to_learn",
      "parallel_eligible": false,
      "skippable_when_present": false
    },
    {
      "name": "retrospective",
      "role": "retrospective",
      "optional": true,
      "enable_var": "EVOLVE_DISABLE_AUTO_RETROSPECTIVE",
      "enable_var_inverted": true,
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/audit-report.md",
          ".evolve/runs/cycle-{cycle}/build-report.md"
        ],
        "state_fields": ["failedApproaches"]
      },
      "outputs": {
        "files": [".evolve/runs/cycle-{cycle}/retrospective-report.md"]
      },
      "gate_in": "gate_audit_to_retrospective",
      "gate_out": "gate_retrospective_to_complete",
      "parallel_eligible": true,
      "skippable_when_present": false
    },
    {
      "name": "memo",
      "role": "memo",
      "optional": true,
      "enable_var": null,
      "inputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/audit-report.md",
          ".evolve/runs/cycle-{cycle}/build-report.md",
          ".evolve/runs/cycle-{cycle}/scout-report.md"
        ],
        "state_fields": []
      },
      "outputs": {
        "files": [
          ".evolve/runs/cycle-{cycle}/memo.md",
          ".evolve/runs/cycle-{cycle}/carryover-todos.json"
        ]
      },
      "gate_in": "gate_ship_to_learn",
      "gate_out": "gate_cycle_complete",
      "parallel_eligible": false,
      "skippable_when_present": false
    }
  ]
}
