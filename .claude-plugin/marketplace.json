{
  "name": "evo",
  "owner": {
    "name": "Dan Lee"
  },
  "metadata": {
    "description": "Self-evolving development pipeline with eval gating, continuous learning, and loop monitoring. 4 agents across 5 phases to autonomously discover, build, audit, and ship improvements."
  },
  "plugins": [
    {
      "name": "evo",
      "source": "./",
      "description": "3 lean agents across 6 phases with compound discovery loop, proactive research, and strict evaluation — RESEARCH, DISCOVER, BUILD, AUDIT, SHIP, LEARN",
      "version": "21.0.0",
      "author": {
        "name": "Dan Lee"
      },
      "homepage": "https://github.com/mickeyyaya/evolve-loop",
      "repository": "https://github.com/mickeyyaya/evolve-loop",
      "license": "Apache-2.0",
      "category": "workflow",
      "tags": [
        "agents",
        "skills",
        "autonomous",
        "pipeline",
        "eval",
        "self-evolving"
      ],
      "compatibility": {
        "primary_cli": "claude-code",
        "tiers": {
          "claude-code": "tier-1",
          "gemini-cli": "tier-1-hybrid",
          "codex-cli": "tier-3-stub"
        },
        "see_also": "docs/platform-compatibility.md"
      },
      "binaries": [
        {
          "name": "evolve",
          "description": "Go orchestrator binary (optional accelerator) — hosts phase runners and serves the phaseproto wire protocol for cross-CLI subprocess agents.",
          "artifacts": {
            "darwin-amd64": "go/bin/dist/evolve-darwin-amd64",
            "darwin-arm64": "go/bin/dist/evolve-darwin-arm64",
            "linux-amd64": "go/bin/dist/evolve-linux-amd64",
            "linux-arm64": "go/bin/dist/evolve-linux-arm64"
          },
          "tier": "tier-1-primary",
          "fallback": {
            "env_var": "EVOLVE_USE_LEGACY_BASH",
            "fallback_path": "archive/legacy/scripts/dispatch/evolve-loop-dispatch.sh"
          }
        }
      ],
      "strict": false
    }
  ]
}
