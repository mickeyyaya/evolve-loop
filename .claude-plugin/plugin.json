{
  "name": "evolve-loop",
  "version": "11.6.1",
  "description": "Self-evolving development pipeline — 3 lean agents across 6 phases with compound discovery loop, proactive research, and strict evaluation. No external dependencies.",
  "author": {
    "name": "Dan Lee"
  },
  "homepage": "https://github.com/mickeyyaya/evolve-loop",
  "repository": "https://github.com/mickeyyaya/evolve-loop",
  "license": "MIT",
  "compatibility": {
    "primary_cli": "claude-code",
    "tiers": {
      "claude-code": "tier-1",
      "gemini-cli": "tier-1-hybrid",
      "codex-cli": "tier-3-stub",
      "other": "tier-4-skill-text-only"
    },
    "tier_notes": {
      "tier-1": "Production. Both skill content and runtime tested.",
      "tier-1-hybrid": "Skill activates via Gemini CLI; runtime delegates to claude binary via legacy/scripts/cli_adapters/gemini.sh. Requires Claude CLI installed.",
      "tier-3-stub": "Adapter exits 99. Skill content is portable; runtime not implemented.",
      "tier-4-skill-text-only": "Documentation portable; no tested runtime adapter."
    },
    "see_also": "docs/platform-compatibility.md"
  },
  "keywords": [
    "claude-code",
    "agents",
    "skills",
    "evolve",
    "autonomous",
    "pipeline",
    "self-evolving",
    "eval"
  ],
  "agents": [
    "./agents/evolve-scout.md",
    "./agents/evolve-builder.md",
    "./agents/evolve-auditor.md",
    "./agents/evolve-operator.md",
    "./agents/evolve-tdd-engineer.md",
    "./agents/evolve-retrospective.md",
    "./agents/evolve-orchestrator.md",
    "./agents/plan-reviewer.md",
    "./agents/evolve-intent.md",
    "./agents/evolve-triage.md",
    "./agents/evolve-memo.md"
  ],
  "skills": [
    "./skills/evolve-loop/",
    "./skills/evolve-spec/",
    "./skills/evolve-plan-review/",
    "./skills/evolve-tdd/",
    "./skills/evolve-build/",
    "./skills/evolve-audit/",
    "./skills/evolve-ship/",
    "./skills/evolve-retro/",
    "./skills/evolve-intent/",
    "./skills/refactor/",
    "./skills/code-review-simplify/",
    "./skills/security-review-scored/",
    "./skills/inspirer/",
    "./skills/evaluator/",
    "./skills/publish/",
    "./skills/verify-release/"
  ],
  "commands": [
    "./.claude-plugin/commands/scout.md",
    "./.claude-plugin/commands/plan-review.md",
    "./.claude-plugin/commands/tdd.md",
    "./.claude-plugin/commands/build.md",
    "./.claude-plugin/commands/audit.md",
    "./.claude-plugin/commands/ship.md",
    "./.claude-plugin/commands/retro.md",
    "./.claude-plugin/commands/loop.md",
    "./.claude-plugin/commands/intent.md"
  ],
  "binaries": [
    {
      "name": "evolve",
      "description": "Go orchestrator binary. Hosts in-process phase runners and serves the phaseproto wire protocol (`evolve serve-phase <name>`) for cross-CLI subprocess agents.",
      "module": "./go",
      "package": "./cmd/evolve",
      "source_build": "cd go && make build",
      "cross_compile": "cd go && make dist",
      "artifacts": {
        "darwin-amd64": "go/bin/dist/evolve-darwin-amd64",
        "darwin-arm64": "go/bin/dist/evolve-darwin-arm64",
        "linux-amd64": "go/bin/dist/evolve-linux-amd64",
        "linux-arm64": "go/bin/dist/evolve-linux-arm64"
      },
      "tier": "tier-1-primary",
      "tier_note": "Primary runtime as of v11.0.0. Bash scripts under legacy/scripts/ remain the authoritative reference and continue to work when the binary is absent. Set EVOLVE_USE_LEGACY_BASH=1 to force the bash dispatch.",
      "fallback": {
        "env_var": "EVOLVE_USE_LEGACY_BASH",
        "fallback_path": "archive/legacy/scripts/dispatch/evolve-loop-dispatch.sh",
        "see_also": "docs/migration-from-bash.md"
      }
    }
  ]
}
