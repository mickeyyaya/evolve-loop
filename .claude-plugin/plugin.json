{
  "name": "evolve-loop",
  "version": "9.0.3",
  "description": "Self-evolving development pipeline — 3 lean agents across 6 phases with compound discovery loop, proactive research, and strict evaluation. No external dependencies.",
  "author": {
    "name": "Dan Lee"
  },
  "homepage": "https://github.com/mickeyyaya/evolve-loop",
  "repository": "https://github.com/mickeyyaya/evolve-loop",
  "license": "MIT",
  "compatibility": {
    "primary_cli": "claude-code",
    "tiers": {
      "claude-code": "tier-1",
      "gemini-cli": "tier-1-hybrid",
      "codex-cli": "tier-3-stub",
      "other": "tier-4-skill-text-only"
    },
    "tier_notes": {
      "tier-1": "Production. Both skill content and runtime tested.",
      "tier-1-hybrid": "Skill activates via Gemini CLI; runtime delegates to claude binary via scripts/cli_adapters/gemini.sh. Requires Claude CLI installed.",
      "tier-3-stub": "Adapter exits 99. Skill content is portable; runtime not implemented.",
      "tier-4-skill-text-only": "Documentation portable; no tested runtime adapter."
    },
    "see_also": "docs/platform-compatibility.md"
  },
  "keywords": [
    "claude-code",
    "agents",
    "skills",
    "evolve",
    "autonomous",
    "pipeline",
    "self-evolving",
    "eval"
  ],
  "agents": [
    "./agents/evolve-scout.md",
    "./agents/evolve-builder.md",
    "./agents/evolve-auditor.md",
    "./agents/evolve-operator.md",
    "./agents/evolve-tdd-engineer.md",
    "./agents/evolve-retrospective.md",
    "./agents/evolve-orchestrator.md",
    "./agents/plan-reviewer.md",
    "./agents/evolve-intent.md",
    "./agents/evolve-triage.md",
    "./agents/evolve-memo.md"
  ],
  "skills": [
    "./skills/evolve-loop/",
    "./skills/evolve-spec/",
    "./skills/evolve-plan-review/",
    "./skills/evolve-tdd/",
    "./skills/evolve-build/",
    "./skills/evolve-audit/",
    "./skills/evolve-ship/",
    "./skills/evolve-retro/",
    "./skills/evolve-intent/",
    "./skills/refactor/",
    "./skills/code-review-simplify/",
    "./skills/inspirer/",
    "./skills/evaluator/",
    "./skills/publish/",
    "./skills/verify-release/"
  ],
  "commands": [
    "./.claude-plugin/commands/scout.md",
    "./.claude-plugin/commands/plan-review.md",
    "./.claude-plugin/commands/tdd.md",
    "./.claude-plugin/commands/build.md",
    "./.claude-plugin/commands/audit.md",
    "./.claude-plugin/commands/ship.md",
    "./.claude-plugin/commands/retro.md",
    "./.claude-plugin/commands/loop.md",
    "./.claude-plugin/commands/intent.md"
  ]
}
