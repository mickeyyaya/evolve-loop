{
  "schema_version": 1,
  "cli": "claude-tmux",
  "binary": "claude",
  "binary_min_version": "2.1.0",
  "default_tier": "hybrid",
  "tier_dependencies": {
    "full":     ["claude", "tmux"],
    "hybrid":   ["claude", "tmux"],
    "degraded": ["claude"]
  },
  "prompt_marker": "❯",
  "default_model": "haiku",
  "default_args": ["--dangerously-skip-permissions"],
  "interactive_prompts": [
    {
      "name": "auth_recheck",
      "regex": "Please log in|Authentication required|Login expired",
      "response_keys": null,
      "policy": "escalate",
      "note": "Bridge cannot complete OAuth; escalate to operator"
    },
    {
      "name": "rate_limit",
      "regex": "rate.?limit|too many requests|429",
      "response_keys": null,
      "policy": "escalate",
      "note": "Operator decides retry vs abandon"
    },
    {
      "name": "model_deprecation_continue",
      "regex": "model is deprecated.*[Cc]ontinue",
      "response_keys": "y\n",
      "policy": "auto_respond",
      "note": "Common edge case Anthropic shows on Sonnet 3 → 4 rollover"
    },
    {
      "name": "terminal_resize_redraw",
      "regex": "Terminal too small.*resize",
      "response_keys": "\n",
      "policy": "auto_respond",
      "note": "Cosmetic; just press enter"
    }
  ]
}
