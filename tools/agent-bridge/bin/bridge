#!/usr/bin/env bash
# bin/bridge — entrypoint for the multi-CLI tmux-driven AI agent bridge

set -uo pipefail

# Resolve the script's REAL location even when invoked via symlink
# (e.g., $HOME/.local/bin/bridge → tools/agent-bridge/bin/bridge).
# Bash 3.2-portable: walk the symlink chain manually since macOS's `readlink`
# lacks -f and `realpath` is not always available.
_bridge_src="${BASH_SOURCE[0]}"
while [[ -L "$_bridge_src" ]]; do
  _bridge_dir="$(cd -P "$(dirname "$_bridge_src")" && pwd)"
  _bridge_src="$(readlink "$_bridge_src")"
  [[ "$_bridge_src" != /* ]] && _bridge_src="$_bridge_dir/$_bridge_src"
done
readonly BRIDGE_SCRIPT_DIR="$(cd -P "$(dirname "$_bridge_src")" && pwd)"
readonly BRIDGE_ROOT="$(cd -P "${BRIDGE_SCRIPT_DIR}/.." && pwd)"
unset _bridge_src _bridge_dir
: "${BRIDGE_LIB_DIR:=${BRIDGE_ROOT}/lib}"
readonly BRIDGE_LIB_DIR
readonly BRIDGE_DRIVERS_DIR="${BRIDGE_ROOT}/drivers"
readonly BRIDGE_VERSION_FILE="${BRIDGE_ROOT}/VERSION"
export BRIDGE_LIB_DIR BRIDGE_DRIVERS_DIR

readonly EC_OK=0
readonly EC_SAFETY_GATE=2
readonly EC_COST_LEAK=3
readonly EC_BAD_FLAGS=10
readonly EC_REPL_BOOT_TIMEOUT=80
readonly EC_ARTIFACT_TIMEOUT=81
readonly EC_UNKNOWN_PROMPT=85
readonly EC_RESPOND_LOOP_GUARD=86
readonly EC_REQUIRE_FULL_UNMET=99
readonly EC_MISSING_BINARY=127

. "${BRIDGE_LIB_DIR}/profile.sh"
. "${BRIDGE_LIB_DIR}/manifest-loader.sh"
. "${BRIDGE_LIB_DIR}/probe.sh"
. "${BRIDGE_LIB_DIR}/auto-respond.sh"
. "${BRIDGE_LIB_DIR}/manifest-patcher.sh"
. "${BRIDGE_LIB_DIR}/report.sh"
. "${BRIDGE_LIB_DIR}/doctor.sh"
. "${BRIDGE_LIB_DIR}/selftest.sh"
. "${BRIDGE_LIB_DIR}/human-input.sh"

cmd_version() {
  local ver="unknown"
  if [[ -r "$BRIDGE_VERSION_FILE" ]]; then
    ver=$(cat "$BRIDGE_VERSION_FILE")
  fi
  if [[ "${BRIDGE_JSON:-0}" == "1" ]]; then
    jq -n --arg v "$ver" '{version: $v, schema_version: 1}'
  else
    echo "$ver"
  fi
  [[ "$ver" == "unknown" ]] && return 1
  return 0
}

cmd_help() {
  cat <<'HELP'
bridge — multi-CLI tmux-driven AI agent bridge

Subcommands:
  launch    Run a subagent invocation through the chosen CLI
  probe     Detect available CLIs and capability tiers (JSON)
  validate  Dry-run: parse profile, print resolved config, exit 0
  report    Re-print structured summary for a past workspace
  add-rule  Append a new interactive_prompts rule to a CLI manifest
  doctor    Pre-flight auth + binary check (JSON: bridge --json doctor)
  selftest  Run the bats test suite (CLI-driven contract verification)
  version   Print the bridge version
  help      Print this help

Exit codes:
  0    success
  2    safety-gate (e.g., bypass guard not acknowledged)
  3    cost-leak (env-var leak: ANTHROPIC_API_KEY, etc.)
  10   bad flags or missing required arg
  80   REPL boot timeout
  81   artifact never appeared
  85   unknown interactive prompt (escalation report written)
  86   auto-respond loop guard tripped
  99   --require-full set and full tier not available
  127  required external binary missing

Run 'bridge launch --help' or 'bridge probe --help' for subcommand flags.
HELP
}

cmd_launch_help() {
  cat <<'LAUNCH_HELP'
bridge launch — run a subagent invocation through the chosen CLI

Required (flag OR env var equivalent):
  --cli=NAME          | BRIDGE_CLI         claude-p | claude-tmux | codex | agy
  --profile=PATH      | PROFILE_PATH       Absolute path to agent profile JSON
  --model=MODEL       | RESOLVED_MODEL     haiku|sonnet|opus|auto|gpt-*|gemini-*
  --prompt-file=PATH  | PROMPT_FILE        Absolute path to prompt text
  --workspace=DIR     | WORKSPACE_PATH     Absolute path to output dir
  --stdout-log=PATH   | STDOUT_LOG         Where to write LLM stdout
  --stderr-log=PATH   | STDERR_LOG         Where to write diagnostics
  --artifact=PATH     | ARTIFACT_PATH      Expected artifact path

Optional:
  --cycle=N           | CYCLE              Cycle number for logging (default: 0)
  --worktree=DIR      | WORKTREE_PATH      Git worktree path if any
  --agent=NAME        | AGENT              Agent role label (default: probe)
  --require-full      | BRIDGE_REQUIRE_FULL=1
                                          Exit 99 if full tier not available
  --validate-only     | VALIDATE_ONLY=1   Dry-run: parse + print resolved config
  --dry-run           | BRIDGE_DRY_RUN=1  Produce mock outputs (no LLM call); rc=0
  --allow-bypass      | BRIDGE_ALLOW_BYPASS=1
                                          Acknowledge --dangerously-skip-permissions
  --permission-mode=M | BRIDGE_PERMISSION_MODE=M
                                          Pass through to `claude --permission-mode M`.
                                          Valid: plan | default | acceptEdits |
                                          bypassPermissions | auto | dontAsk.
                                          Precedence: CLI flag > env var > profile.permission_mode.
                                          In plan mode (claude-tmux driver), --dangerously-skip-permissions
                                          is replaced (not augmented) — plan mode disables writes by
                                          design, so --allow-bypass is NOT required when permission-mode=plan.
  --stream-output     | BRIDGE_STREAM_OUTPUT=1
                                          (v0.3+) claude-p only: append --output-format=stream-json
                                          --include-partial-messages --verbose so claude emits realtime
                                          JSONL events to stdout. Solves phase-observer false-positive
                                          stall kills on long orchestrator sessions. Other drivers log
                                          a NOTE that the flag is no-op. Precedence: flag > env > profile.
                                          Use --no-stream-output to explicitly disable when env/profile sets it.
  --session-name=NAME | BRIDGE_SESSION_NAME=NAME
                                          (v0.5+) *-tmux drivers only: use STABLE tmux session name
                                          `evolve-bridge-named-<NAME>`. Sessions persist across exits
                                          (trap doesn't kill), are EXEMPT from orphan-sweep, and
                                          auto-resume on next launch (claude REPL context preserved).
                                          Cleanup: `bridge sessions kill NAME` (or `tmux kill-session
                                          -t evolve-bridge-named-NAME`). Valid chars: [a-zA-Z0-9._-]+,
                                          max 32 chars. Non-tmux drivers log a NOTE that it's no-op.

Session lifecycle (v0.4+):
  Every launch creates a fresh context-window session (claude-p/codex/agy: new
  single-shot process; *-tmux: new uniquely-named tmux session). Trap-based
  cleanup kills tmux sessions on normal EXIT, INT, and TERM. SIGKILL/OOM
  cannot be trapped and DOES leak sessions — the orphan-sweep on each new
  launch finds dead-pid `evolve-bridge-*` sessions and kills them. Opt-out:
  BRIDGE_NO_ORPHAN_CLEANUP=1 (only if you have a long-running session whose
  bridge parent was killed but you want to keep the tmux for manual access).

Flags always win when both flag and env var are set.

The contract mirrors a common cli_adapter env-var convention,
so bridge is a friction-free drop-in: a caller exporting PROFILE_PATH etc. can
invoke `bridge launch --cli=NAME` with no other flags.
LAUNCH_HELP
}

# Helper: write the dry-run mock outputs and return 0
_bridge_dry_run() {
  local cli="$1" profile="$2" model="$3" prompt_file="$4" workspace="$5"
  local stdout_log="$6" stderr_log="$7" artifact="$8"
  local cycle="$9" agent="${10}"

  mkdir -p "$workspace" "$(dirname "$stdout_log")" "$(dirname "$stderr_log")" "$(dirname "$artifact")"

  # Resolve challenge token (so dry-run output matches the real path's invariant)
  local prompt_content
  prompt_content="$(cat "$prompt_file" 2>/dev/null || echo "(prompt file unreadable)")"
  local challenge_token=""
  if [[ "$prompt_content" == *'$CHALLENGE_TOKEN'* ]]; then
    challenge_token="$(openssl rand -hex 8 2>/dev/null || echo "drytoken")"
    echo "$challenge_token" > "$workspace/challenge-token.txt"
  fi

  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  local prompt_bytes
  prompt_bytes=$(wc -c < "$prompt_file" 2>/dev/null | tr -d ' ')

  # Mock stdout-log — what the real CLI would have printed
  cat > "$stdout_log" <<DRYSTDOUT
[bridge dry-run] mock stdout — no LLM invoked
cli=$cli model=$model cycle=$cycle agent=$agent
prompt_bytes=$prompt_bytes
artifact=$artifact
DRYSTDOUT

  # Mock stderr-log — bridge's own trace
  cat > "$stderr_log" <<DRYSTDERR
[bridge dry-run] $now
[bridge dry-run] would have invoked cli=$cli driver=drivers/${cli}.sh
[bridge dry-run] model=$model profile.name=$bridge_profile_name
[bridge dry-run] allowed_tools=$bridge_profile_allowed_tools_csv
[bridge dry-run] prompt_bytes=$prompt_bytes
[bridge dry-run] artifact=$artifact
[bridge dry-run] NO real call made; rc=0
DRYSTDERR

  # Mock artifact — the phase agent's expected output shape, with the
  # challenge token so artifact-verification passes if it checks for one.
  cat > "$artifact" <<DRYARTIFACT
<!-- challenge-token: ${challenge_token:-no-token} -->
<!-- bridge-dry-run: ${now} -->
# bridge dry-run — synthetic phase agent output

This artifact was produced by \`bridge launch --dry-run\`. It satisfies the
phase agent's artifact-path contract without invoking any LLM.

## Resolved config

- cli: $cli
- model: $model
- profile.name: $bridge_profile_name
- profile.allowed_tools: $bridge_profile_allowed_tools_csv
- cycle: $cycle
- agent: $agent
- prompt_bytes: $prompt_bytes
- artifact_path: $artifact
- timestamp: $now

## Mock content

DRY-RUN-OK — no LLM was called.

To execute against a real LLM, remove the \`--dry-run\` flag (or unset
\`BRIDGE_DRY_RUN\`).
DRYARTIFACT

  echo "[bridge] dry-run complete: artifact=$artifact stdout_log=$stdout_log" >&2
  return $EC_OK
}

cmd_launch() {
  # Initialize from env vars (env values are fallbacks; flags override below)
  local cli="${BRIDGE_CLI:-}"
  local profile="${PROFILE_PATH:-}"
  local model="${RESOLVED_MODEL:-}"
  local prompt_file="${PROMPT_FILE:-}"
  local workspace="${WORKSPACE_PATH:-}"
  local stdout_log="${STDOUT_LOG:-}"
  local stderr_log="${STDERR_LOG:-}"
  local artifact="${ARTIFACT_PATH:-}"
  local cycle="${CYCLE:-0}"
  local worktree="${WORKTREE_PATH:-}"
  local agent="${AGENT:-probe}"
  local validate_only="${VALIDATE_ONLY:-0}"
  local require_full="${BRIDGE_REQUIRE_FULL:-0}"
  local allow_bypass="${BRIDGE_ALLOW_BYPASS:-0}"
  local dry_run="${BRIDGE_DRY_RUN:-0}"
  local human_input="${BRIDGE_HUMAN_INPUT_FLAG:-0}"
  # v0.2: --permission-mode for claude --permission-mode pass-through.
  # Empty = use profile.permission_mode (or driver default if neither set).
  # Valid: plan | default | acceptEdits | bypassPermissions | auto | dontAsk
  local permission_mode="${BRIDGE_PERMISSION_MODE:-}"
  # v0.3: --stream-output (boolean flag) — claude-p only. When effective true,
  # appends --output-format=stream-json --include-partial-messages so claude
  # emits realtime JSONL events to stdout. Solves phase-observer false-positive
  # stall kills on long orchestrator sessions where claude -p's default text
  # output stays silent until the final response.
  # Empty string here means "honor env/profile" (which default to false).
  local stream_output="${BRIDGE_STREAM_OUTPUT:-}"
  # v0.5: --session-name=NAME — *-tmux drivers only. Uses STABLE tmux session
  # name `evolve-bridge-named-<NAME>` instead of pid-and-timestamp. Named
  # sessions persist across bridge exits (trap doesn't kill), are EXEMPT
  # from orphan-sweep, and auto-resume on next launch (claude REPL context
  # preserved). Cleanup via `bridge sessions kill NAME`.
  local session_name="${BRIDGE_SESSION_NAME:-}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cli=*)         cli="${1#--cli=}" ;;
      --cli)           [[ $# -ge 2 ]] || { echo "[bridge] --cli requires a value" >&2; return $EC_BAD_FLAGS; }; cli="$2"; shift ;;
      --profile=*)     profile="${1#--profile=}" ;;
      --profile)       [[ $# -ge 2 ]] || { echo "[bridge] --profile requires a value" >&2; return $EC_BAD_FLAGS; }; profile="$2"; shift ;;
      --model=*)       model="${1#--model=}" ;;
      --model)         [[ $# -ge 2 ]] || { echo "[bridge] --model requires a value" >&2; return $EC_BAD_FLAGS; }; model="$2"; shift ;;
      --prompt-file=*) prompt_file="${1#--prompt-file=}" ;;
      --prompt-file)   [[ $# -ge 2 ]] || { echo "[bridge] --prompt-file requires a value" >&2; return $EC_BAD_FLAGS; }; prompt_file="$2"; shift ;;
      --workspace=*)   workspace="${1#--workspace=}" ;;
      --workspace)     [[ $# -ge 2 ]] || { echo "[bridge] --workspace requires a value" >&2; return $EC_BAD_FLAGS; }; workspace="$2"; shift ;;
      --stdout-log=*)  stdout_log="${1#--stdout-log=}" ;;
      --stdout-log)    [[ $# -ge 2 ]] || { echo "[bridge] --stdout-log requires a value" >&2; return $EC_BAD_FLAGS; }; stdout_log="$2"; shift ;;
      --stderr-log=*)  stderr_log="${1#--stderr-log=}" ;;
      --stderr-log)    [[ $# -ge 2 ]] || { echo "[bridge] --stderr-log requires a value" >&2; return $EC_BAD_FLAGS; }; stderr_log="$2"; shift ;;
      --artifact=*)    artifact="${1#--artifact=}" ;;
      --artifact)      [[ $# -ge 2 ]] || { echo "[bridge] --artifact requires a value" >&2; return $EC_BAD_FLAGS; }; artifact="$2"; shift ;;
      --cycle=*)       cycle="${1#--cycle=}" ;;
      --cycle)         [[ $# -ge 2 ]] || { echo "[bridge] --cycle requires a value" >&2; return $EC_BAD_FLAGS; }; cycle="$2"; shift ;;
      --worktree=*)    worktree="${1#--worktree=}" ;;
      --worktree)      [[ $# -ge 2 ]] || { echo "[bridge] --worktree requires a value" >&2; return $EC_BAD_FLAGS; }; worktree="$2"; shift ;;
      --agent=*)       agent="${1#--agent=}" ;;
      --agent)         [[ $# -ge 2 ]] || { echo "[bridge] --agent requires a value" >&2; return $EC_BAD_FLAGS; }; agent="$2"; shift ;;
      --validate-only) validate_only=1 ;;
      --dry-run)       dry_run=1 ;;
      --require-full)  require_full=1 ;;
      --allow-bypass)  allow_bypass=1 ;;
      --human-input)   human_input=1 ;;
      --permission-mode=*) permission_mode="${1#--permission-mode=}" ;;
      --permission-mode)   [[ $# -ge 2 ]] || { echo "[bridge] --permission-mode requires a value" >&2; return $EC_BAD_FLAGS; }; permission_mode="$2"; shift ;;
      --stream-output)     stream_output=true ;;
      --no-stream-output)  stream_output=false ;;
      --session-name=*)    session_name="${1#--session-name=}" ;;
      --session-name)      [[ $# -ge 2 ]] || { echo "[bridge] --session-name requires a value" >&2; return $EC_BAD_FLAGS; }; session_name="$2"; shift ;;
      --help|-h)       cmd_launch_help; return $EC_OK ;;
      --)              shift; break ;;
      *)               echo "[bridge] launch: unknown flag: $1" >&2; return $EC_BAD_FLAGS ;;
    esac
    shift
  done

  # Validate required (after flag-vs-env merge)
  local missing=()
  [[ -z "$cli" ]]         && missing+=("--cli/BRIDGE_CLI")
  [[ -z "$profile" ]]     && missing+=("--profile/PROFILE_PATH")
  [[ -z "$model" ]]       && missing+=("--model/RESOLVED_MODEL")
  [[ -z "$prompt_file" ]] && missing+=("--prompt-file/PROMPT_FILE")
  [[ -z "$workspace" ]]   && missing+=("--workspace/WORKSPACE_PATH")
  [[ -z "$stdout_log" ]]  && missing+=("--stdout-log/STDOUT_LOG")
  [[ -z "$stderr_log" ]]  && missing+=("--stderr-log/STDERR_LOG")
  [[ -z "$artifact" ]]    && missing+=("--artifact/ARTIFACT_PATH")
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "[bridge] launch: missing required (flag or env): ${missing[*]}" >&2
    return $EC_BAD_FLAGS
  fi

  if ! profile_load "$profile"; then
    return $EC_BAD_FLAGS
  fi

  # --human-input gate: requires host-level BRIDGE_HUMAN_SIMULATION=1 env opt-in.
  # Two-gate design (see docs/design.md §8 and lib/human-input.sh header).
  if [[ "$human_input" -eq 1 ]] && [[ "${BRIDGE_HUMAN_SIMULATION:-0}" != "1" ]]; then
    echo "[bridge] --human-input requires BRIDGE_HUMAN_SIMULATION=1 host opt-in" >&2
    echo "[bridge] See docs/design.md §8 for the policy framing + per-CLI ToS responsibility." >&2
    return $EC_SAFETY_GATE
  fi
  # Export so the driver and lib/human-input.sh see it
  export human_input

  if [[ ! -r "$prompt_file" ]]; then
    echo "[bridge] launch: prompt file not readable: $prompt_file" >&2
    return $EC_BAD_FLAGS
  fi
  # F5: empty-prompt guard — silently sending empty input would hang the agent
  # at the 300s artifact timeout. Fail fast with a clear message.
  if [[ ! -s "$prompt_file" ]]; then
    echo "[bridge] launch: prompt file is empty: $prompt_file" >&2
    echo "[bridge] (an empty prompt would hang the agent at the artifact timeout)" >&2
    return $EC_BAD_FLAGS
  fi
  # F6: workspace-reuse warning — caller may have passed a stale workspace.
  # Fires BEFORE validate-only/dry-run checks so the operator is warned
  # regardless of how the launch resolves.
  if [[ -d "$workspace" ]] && { [[ -f "$workspace/artifact.md" ]] || [[ -f "$workspace/escalation-report.json" ]]; }; then
    local stale=()
    [[ -f "$workspace/artifact.md" ]] && stale+=("artifact.md")
    [[ -f "$workspace/escalation-report.json" ]] && stale+=("escalation-report.json")
    echo "[bridge] WARN: workspace contains stale files from a prior run: ${stale[*]}" >&2
    echo "[bridge] (proceeding; files will be overwritten by this launch)" >&2
  fi

  local effective_model="$model"
  if [[ "$model" == "auto" ]]; then
    if [[ -n "$bridge_profile_model" ]]; then
      effective_model="$bridge_profile_model"
    else
      effective_model="auto"  # driver decides default
    fi
  fi

  # Resolve effective permission_mode: CLI flag > env var > profile field.
  # Empty string means "driver picks its native default" (back-compat).
  local effective_permission_mode="$permission_mode"
  if [[ -z "$effective_permission_mode" ]] && [[ -n "${bridge_profile_permission_mode:-}" ]]; then
    effective_permission_mode="$bridge_profile_permission_mode"
  fi
  # Re-validate at the resolution point: an operator-passed --permission-mode
  # bypasses profile_load's validation, so we check here too.
  case "$effective_permission_mode" in
    ""|plan|default|acceptEdits|bypassPermissions|auto|dontAsk) ;;
    *)
      echo "[bridge] invalid --permission-mode value: '$effective_permission_mode'" >&2
      echo "[bridge] valid: plan, default, acceptEdits, bypassPermissions, auto, dontAsk" >&2
      return $EC_BAD_FLAGS
      ;;
  esac
  export effective_permission_mode

  # v0.3: Resolve effective stream_output (boolean): CLI flag > env > profile > false.
  # Normalize various truthy/falsy inputs to canonical "true" | "false" strings
  # so drivers can do plain `[[ "$x" == "true" ]]` checks.
  local effective_stream_output="$stream_output"
  if [[ -z "$effective_stream_output" ]]; then
    # No flag set; fall through to profile default (which itself defaults to "false").
    effective_stream_output="${bridge_profile_stream_output:-false}"
  fi
  case "$effective_stream_output" in
    true|1|yes|on)   effective_stream_output=true ;;
    false|0|no|off|"") effective_stream_output=false ;;
    *)
      echo "[bridge] invalid --stream-output value: '$effective_stream_output' — must be boolean (true|false|1|0|yes|no|on|off)" >&2
      return $EC_BAD_FLAGS
      ;;
  esac
  export effective_stream_output

  # v0.5: Resolve effective session_name: CLI flag > env > profile > "".
  # Re-validate at the resolution point: an operator-passed --session-name
  # bypasses profile_load's validation, so we check here too.
  local effective_session_name="$session_name"
  if [[ -z "$effective_session_name" ]] && [[ -n "${bridge_profile_session_name:-}" ]]; then
    effective_session_name="$bridge_profile_session_name"
  fi
  if [[ -n "$effective_session_name" ]]; then
    if [[ ${#effective_session_name} -gt 32 ]]; then
      echo "[bridge] invalid --session-name (length ${#effective_session_name} > 32 chars)" >&2
      return $EC_BAD_FLAGS
    fi
    if [[ ! "$effective_session_name" =~ ^[a-zA-Z0-9._-]+$ ]]; then
      echo "[bridge] invalid --session-name '$effective_session_name' — must match [a-zA-Z0-9._-]+ (no shell metachars)" >&2
      return $EC_BAD_FLAGS
    fi
  fi
  export effective_session_name

  # --validate-only: print resolved config and exit
  if [[ "$validate_only" -eq 1 ]]; then
    cat <<RESOLVED
[bridge] validate-only — resolved config:
  cli            = $cli
  profile        = $profile
  profile.name   = $bridge_profile_name
  profile.model  = $bridge_profile_model
  model          = $effective_model
  prompt         = $prompt_file
  workspace      = $workspace
  stdout-log     = $stdout_log
  stderr-log     = $stderr_log
  artifact       = $artifact
  cycle          = $cycle
  worktree       = $worktree
  agent          = $agent
  allowed_tools  = $bridge_profile_allowed_tools_csv
  permission-mode = ${effective_permission_mode:-(driver default)}
  stream-output  = $effective_stream_output
  session-name   = ${effective_session_name:-(auto-generated, ephemeral)}
  auto_respond:
    destructive_ops = $bridge_profile_auto_respond_destructive_ops
    timeout_s       = $bridge_profile_auto_respond_timeout_s
  prompt_overrides = $bridge_profile_prompt_overrides_count entries
  require-full   = $require_full
  allow-bypass   = $allow_bypass
  dry-run        = $dry_run
  human-input    = $human_input
RESOLVED
    return $EC_OK
  fi

  # --dry-run: produce mock outputs, no driver dispatch
  if [[ "$dry_run" -eq 1 ]]; then
    _bridge_dry_run "$cli" "$profile" "$effective_model" "$prompt_file" \
      "$workspace" "$stdout_log" "$stderr_log" "$artifact" \
      "$cycle" "$agent"
    local dry_rc=$?
    if [[ "${BRIDGE_JSON:-0}" == "1" ]]; then
      bridge_report_with_exists "$workspace" "$(basename "$artifact")" 2>/dev/null \
        | jq -c . 2>/dev/null || true
    fi
    return $dry_rc
  fi

  # --require-full check
  if [[ "$require_full" -eq 1 ]]; then
    local tier
    tier="$(probe_resolve_tier "$cli")"
    if [[ "$tier" != "full" && "$tier" != "hybrid" ]]; then
      echo "[bridge] --require-full set; cli=$cli tier=$tier (need full or hybrid)" >&2
      return $EC_REQUIRE_FULL_UNMET
    fi
  fi

  # v0.4: orphan tmux-session sweep. Bridge tmux drivers (claude-tmux,
  # codex-tmux, agy-tmux) create sessions named
  #   evolve-bridge-(c\d+|codex|agy)-...-pid<N>-<timestamp>
  # On normal exit/INT/TERM the driver's trap kills the session. But SIGKILL,
  # OOM-kill, kernel-panic etc. cannot be trapped — they leak sessions.
  # This sweep finds orphan sessions (owner pid no longer alive) and kills them
  # before the new launch creates more, preventing accumulation.
  # Opt-out: BRIDGE_NO_ORPHAN_CLEANUP=1
  if [[ "${BRIDGE_NO_ORPHAN_CLEANUP:-0}" != "1" ]] && command -v tmux >/dev/null 2>&1; then
    local _orphan_ses _orphan_pid _orphan_killed=0
    while IFS= read -r _orphan_ses; do
      [[ -z "$_orphan_ses" ]] && continue
      # v0.5: EXEMPT named sessions (evolve-bridge-named-*) from sweep —
      # they're stable identifiers operators rely on for resume.
      case "$_orphan_ses" in
        evolve-bridge-named-*) continue ;;
      esac
      # Parse pid from "<...>-pid<N>-<ts>" suffix
      _orphan_pid="${_orphan_ses##*-pid}"
      _orphan_pid="${_orphan_pid%%-*}"
      if [[ "$_orphan_pid" =~ ^[0-9]+$ ]]; then
        if ! kill -0 "$_orphan_pid" 2>/dev/null; then
          echo "[bridge] orphan-sweep: killing tmux session '$_orphan_ses' (owner pid $_orphan_pid is dead)" >&2
          tmux kill-session -t "$_orphan_ses" 2>/dev/null || true
          _orphan_killed=$((_orphan_killed + 1))
        fi
      fi
    done < <(tmux ls 2>/dev/null | awk -F: '/^evolve-bridge-/ { print $1 }')
    if [[ "$_orphan_killed" -gt 0 ]]; then
      echo "[bridge] orphan-sweep: killed $_orphan_killed leaked session(s)" >&2
    fi
    unset _orphan_ses _orphan_pid _orphan_killed
  fi

  # Driver dispatch
  local driver_script="${BRIDGE_DRIVERS_DIR}/${cli}.sh"
  if [[ ! -f "$driver_script" ]]; then
    echo "[bridge] no driver for cli=$cli (looked at $driver_script)" >&2
    return $EC_BAD_FLAGS
  fi
  # shellcheck disable=SC1090
  . "$driver_script"
  local fn_name="drv_launch_${cli//-/_}"
  if ! type "$fn_name" >/dev/null 2>&1; then
    echo "[bridge] driver $driver_script does not define $fn_name" >&2
    return $EC_BAD_FLAGS
  fi

  set +e
  $fn_name
  local launch_rc=$?
  set -e

  # --json mode: emit a one-line JSON summary on stdout (same schema as
  # `bridge report`). Emits even on failure paths so a skill can parse the
  # workspace state regardless of rc.
  if [[ "${BRIDGE_JSON:-0}" == "1" ]]; then
    bridge_report_with_exists "$workspace" "$(basename "$artifact")" 2>/dev/null \
      | jq -c . 2>/dev/null || true
  fi

  return $launch_rc
}

cmd_probe() {
  local filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cli=*) filter="${1#--cli=}" ;;
      --cli)   [[ $# -ge 2 ]] || { echo "[bridge] probe --cli requires a value" >&2; return $EC_BAD_FLAGS; }; filter="$2"; shift ;;
      --help|-h)
        cat <<'PROBE_HELP'
bridge probe — detect available CLIs and capability tiers (JSON)

Usage:
  bridge probe                  # all known CLIs
  bridge probe --cli=NAME       # single CLI
PROBE_HELP
        return $EC_OK ;;
      *) echo "[bridge] probe: unknown flag: $1" >&2; return $EC_BAD_FLAGS ;;
    esac
    shift
  done
  probe_all "$filter"
}

cmd_validate() {
  echo "[bridge] validate: pass --validate-only to launch for now" >&2
  return $EC_OK
}

cmd_report() {
  local workspace="" artifact_name="artifact.md"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace=*)     workspace="${1#--workspace=}" ;;
      --workspace)       [[ $# -ge 2 ]] || { echo "[bridge] report --workspace requires a value" >&2; return $EC_BAD_FLAGS; }; workspace="$2"; shift ;;
      --artifact-name=*) artifact_name="${1#--artifact-name=}" ;;
      --artifact-name)   [[ $# -ge 2 ]] || { echo "[bridge] report --artifact-name requires a value" >&2; return $EC_BAD_FLAGS; }; artifact_name="$2"; shift ;;
      --help|-h)
        cat <<'REPORT_HELP'
bridge report — emit JSON summary of a past workspace

Usage:
  bridge report --workspace=PATH [--artifact-name=NAME]

Required:
  --workspace=PATH    Directory written by a prior `bridge launch`

Optional:
  --artifact-name=N   Artifact filename inside the workspace (default: artifact.md)

Output: a JSON object on stdout describing:
  - workspace path + scan timestamp
  - artifact: { path, exists, size_bytes, has_challenge_token }
  - challenge_token (if challenge-token.txt was written)
  - logs: stdout_log / stderr_log / tmux_scrollback / resolved_prompt (each: { path, exists, size_bytes })
  - escalation_report: { path, exists } (auto-respond bail trail)
  - auto_respond_counts: { path, exists }
  - billing_snapshots: [{ path, label, ts }, ...]
  - verdict: complete | escalated | incomplete | incomplete-token-mismatch | unknown
REPORT_HELP
        return $EC_OK
        ;;
      *) echo "[bridge] report: unknown flag: $1" >&2; return $EC_BAD_FLAGS ;;
    esac
    shift
  done

  [[ -z "$workspace" ]] && { echo "[bridge] report: --workspace required" >&2; return $EC_BAD_FLAGS; }
  [[ ! -d "$workspace" ]] && { echo "[bridge] report: workspace not a directory: $workspace" >&2; return $EC_BAD_FLAGS; }

  bridge_report_with_exists "$workspace" "$artifact_name"
}

cmd_add_rule() {
  local escalation="" regex="" response="" policy="" name="" note="" cli=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --escalation=*) escalation="${1#--escalation=}" ;;
      --escalation)   [[ $# -ge 2 ]] || { echo "[bridge] --escalation requires a value" >&2; return $EC_BAD_FLAGS; }; escalation="$2"; shift ;;
      --regex=*)      regex="${1#--regex=}" ;;
      --regex)        [[ $# -ge 2 ]] || { echo "[bridge] --regex requires a value" >&2; return $EC_BAD_FLAGS; }; regex="$2"; shift ;;
      --response=*)   response="${1#--response=}" ;;
      --response)     [[ $# -ge 2 ]] || { echo "[bridge] --response requires a value" >&2; return $EC_BAD_FLAGS; }; response="$2"; shift ;;
      --policy=*)     policy="${1#--policy=}" ;;
      --policy)       [[ $# -ge 2 ]] || { echo "[bridge] --policy requires a value" >&2; return $EC_BAD_FLAGS; }; policy="$2"; shift ;;
      --name=*)       name="${1#--name=}" ;;
      --name)         [[ $# -ge 2 ]] || { echo "[bridge] --name requires a value" >&2; return $EC_BAD_FLAGS; }; name="$2"; shift ;;
      --note=*)       note="${1#--note=}" ;;
      --note)         [[ $# -ge 2 ]] || { echo "[bridge] --note requires a value" >&2; return $EC_BAD_FLAGS; }; note="$2"; shift ;;
      --cli=*)        cli="${1#--cli=}" ;;
      --cli)          [[ $# -ge 2 ]] || { echo "[bridge] --cli requires a value" >&2; return $EC_BAD_FLAGS; }; cli="$2"; shift ;;
      --help|-h)
        cat <<'ADD_RULE_HELP'
bridge add-rule — append an interactive_prompts entry to a CLI manifest
Use --escalation=PATH to ingest a workspace/escalation-report.json, or pass
--cli=NAME directly. See docs/cli-reference.md for full flag table.
ADD_RULE_HELP
        return $EC_OK
        ;;
      *) echo "[bridge] add-rule: unknown flag: $1" >&2; return $EC_BAD_FLAGS ;;
    esac
    shift
  done

  if [[ -n "$escalation" ]]; then
    [[ -f "$escalation" ]] || { echo "[bridge] add-rule: escalation report not found: $escalation" >&2; return $EC_BAD_FLAGS; }
    jq -e . "$escalation" >/dev/null 2>&1 || { echo "[bridge] add-rule: invalid JSON: $escalation" >&2; return $EC_BAD_FLAGS; }
    [[ -z "$cli" ]] && cli="$(jq -r '.cli // ""' "$escalation")"
    [[ -z "$note" ]] && note="Added from escalation $(basename "$escalation") on $(date -u +%Y-%m-%d)"
  fi

  [[ -z "$cli" ]]   && { echo "[bridge] add-rule: --cli is required (or use --escalation)" >&2; return $EC_BAD_FLAGS; }
  [[ -z "$regex" ]] && { echo "[bridge] add-rule: --regex is required" >&2; return $EC_BAD_FLAGS; }
  [[ -z "$policy" ]] && policy=$([[ -n "$response" ]] && echo "auto_respond" || echo "escalate")
  [[ -z "$name" ]] && name="${cli//-/_}_rule_$(date +%s)"

  local manifest_path="${BRIDGE_LIB_DIR}/manifests/${cli}.json"
  set +e
  manifest_append_rule "$manifest_path" "$name" "$regex" "$response" "$policy" "$note"
  local rc=$?
  set -e

  if [[ "${BRIDGE_JSON:-0}" == "1" ]]; then
    local status_str
    case "$rc" in
      0) status_str="appended" ;;
      2) status_str="duplicate" ;;
      *) status_str="failed" ;;
    esac
    jq -n --arg status "$status_str" --arg name "$name" --arg manifest "$manifest_path" \
      --arg policy "$policy" --argjson rc "$rc" \
      '{status: $status, name: $name, manifest: $manifest, policy: $policy, rc: $rc}'
  fi
  return $rc
}


cmd_doctor() {
  bridge_doctor "$@"
}


cmd_selftest() {
  bridge_selftest "$@"
}

main() {
  # Top-level flags parsed BEFORE the subcommand. Currently: --json.
  # Subcommands inspect $BRIDGE_JSON to switch output format.
  local json_mode=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_mode=1; shift ;;
      --)     shift; break ;;
      --*)    break ;;
      *)      break ;;
    esac
  done
  export BRIDGE_JSON="$json_mode"

  if [[ $# -eq 0 ]]; then
    echo "[bridge] no subcommand given. Run 'bridge help'." >&2
    return $EC_BAD_FLAGS
  fi
  local sub="$1"; shift
  case "$sub" in
    launch)            cmd_launch "$@" ;;
    probe)             cmd_probe "$@" ;;
    validate)          cmd_validate "$@" ;;
    report)            cmd_report "$@" ;;
    add-rule)          cmd_add_rule "$@" ;;
    doctor)            cmd_doctor "$@" ;;
    selftest)          cmd_selftest "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)    cmd_help ;;
    *)
      echo "[bridge] unknown subcommand: $sub. Run 'bridge help'." >&2
      return $EC_BAD_FLAGS
      ;;
  esac
}

main "$@"
exit $?
