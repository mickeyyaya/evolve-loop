{
  "_comment": "CLI-agnostic capability tier → concrete model translation. Single source of truth for model IDs per CLI. Update when vendors ship new models or retire old ones.",
  "_target_path": "scripts/routing/tier-map.json",
  "_authoritative_as_of": "2026-05-17",
  "_review_cadence": "quarterly (or on vendor model GA/retirement)",
  "schema_version": 1,
  "tiers": {
    "deep": {
      "_purpose": "Adversarial review, post-mortem reasoning, multi-lens verdicts, RED-phase test design, goal interpretation under uncertainty. Reasoning quality compounds across cycles.",
      "claude":  { "model": "opus",                          "concrete": "claude-opus-4-7",                "thinking": "extended"     },
      "gemini":  { "model": "gemini-3.1-pro-preview",        "concrete": "gemini-3.1-pro-preview",         "thinkingLevel": "high"    },
      "codex":   { "model": "gpt-5.5",                       "concrete": "gpt-5.5",                        "reasoning": "high"        },
      "grok":    { "model": "grok-4-heavy",                  "concrete": "grok-4-heavy",                   "agents": 16               }
    },
    "balanced": {
      "_purpose": "Code generation, structured scan + reporting, predicate authorship, procedural sequencing. Sonnet-class sweet spot.",
      "claude":  { "model": "sonnet",                        "concrete": "claude-sonnet-4-6",              "thinking": "default"      },
      "gemini":  { "model": "gemini-3-pro-preview",          "concrete": "gemini-3-pro-preview",           "thinkingLevel": "medium"  },
      "codex":   { "model": "gpt-5.3-codex",                 "concrete": "gpt-5.3-codex",                  "reasoning": "medium",     "_note": "coding-specialized variant" },
      "grok":    { "model": "grok-4-3",                      "concrete": "grok-4-3",                       "context": "2M"            }
    },
    "fast": {
      "_purpose": "Summarization of pre-structured artifacts, rubric scoring, pattern-match against pre-analyzed lists. No reasoning headroom required.",
      "claude":  { "model": "haiku",                         "concrete": "claude-haiku-4-5-20251001",      "thinking": "default"      },
      "gemini":  { "model": "gemini-3-flash-lite-preview",   "concrete": "gemini-3-flash-lite-preview",    "thinkingLevel": "low"     },
      "codex":   { "model": "gpt-5.4-mini",                  "concrete": "gpt-5.4-mini",                   "reasoning": "low"         },
      "grok":    { "model": "grok-4-20-non-reasoning",       "concrete": "grok-4-20-non-reasoning"                                    }
    }
  },
  "families": {
    "_purpose": "Used by envelope-check.sh to enforce cross_family_with invariant. Two CLIs share a family if they originate from the same model lineage (e.g. all OpenAI-trained models, all Anthropic-trained models).",
    "claude":  "anthropic",
    "gemini":  "google",
    "codex":   "openai",
    "grok":    "xai"
  },
  "cli_capabilities": {
    "_purpose": "Used by decision function + envelope-check to gate phase assignment. Capabilities are documented as supported / degraded / unsupported.",
    "claude":  { "sandbox": "supported", "permission_scoping": "supported", "budget_cap": "supported",        "challenge_token_binding": "supported"                              },
    "gemini":  { "sandbox": "degraded",  "permission_scoping": "degraded",  "budget_cap": "degraded",         "challenge_token_binding": "degraded", "_phase4_target": "supported" },
    "codex":   { "sandbox": "degraded",  "permission_scoping": "degraded",  "budget_cap": "degraded",         "challenge_token_binding": "degraded", "_phase4_target": "supported" },
    "grok":    { "sandbox": "unsupported", "permission_scoping": "unsupported", "budget_cap": "unsupported",  "challenge_token_binding": "degraded", "_phase4_target": "degraded"  }
  },
  "_safety_critical_phases": {
    "_purpose": "Phases that write code or modify the repo. Must use a CLI where ALL safety capabilities are 'supported'. Currently only 'claude'. Lifted when 3P CLIs reach parity (Phase 4).",
    "phases": ["builder", "tester", "tdd-engineer"]
  }
}
