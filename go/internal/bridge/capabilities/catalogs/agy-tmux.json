{
  "cli": "agy-tmux",
  "display_name": "Google Antigravity CLI",
  "slash_commands": [
    { "name": "/help", "purpose": "List every command and keyboard shortcut" },
    { "name": "/usage", "purpose": "Quota / rate-limit status across models" },
    { "name": "/model", "purpose": "Open the model selector; persists across sessions" },
    { "name": "/permissions", "purpose": "Toggle autonomy: request-review | always-proceed | strict" },
    { "name": "/keybindings", "purpose": "Open the keyboard-shortcut editor" },
    { "name": "/config", "purpose": "Open the settings editor" },
    { "name": "/resume", "purpose": "Open the conversation picker" },
    { "name": "/rewind", "purpose": "Rewind history to a checkpoint" },
    { "name": "/fork", "purpose": "Branch the conversation" },
    { "name": "/clear", "purpose": "Start a fresh session" },
    { "name": "/tasks", "purpose": "Inspect or kill background tasks" },
    { "name": "/skills", "purpose": "Browse local + global skill workflows" },
    { "name": "/mcp", "purpose": "Manage MCP server connections" },
    { "name": "/fast", "purpose": "Skip the plan, execute directly" },
    { "name": "/export", "purpose": "Push session into the Antigravity desktop app" },
    { "name": "/agent", "purpose": "Spawn async subagent for a background task", "args": "<task>" },
    { "name": "/goal", "purpose": "Run autonomously until done" }
  ],
  "key_bindings": [
    { "keys": "?", "action": "Open help / slash-command index (the '? for shortcuts' footer)" },
    { "keys": "Esc Esc", "action": "Empty the prompt" },
    { "keys": "@", "action": "File-attachment picker" },
    { "keys": "!", "action": "Run a raw shell command" }
  ],
  "extension": {
    "kind": "skills_mcp",
    "summary": "No marketplace. File-config under ~/.gemini/ (shared across CLI + IDE): MCP servers (mcp_config.json), skills (~/.gemini/skills/<name>/ or project .agents/skills/), plugins/hooks/subagents. Browse live via /skills and /mcp.",
    "install_flow": [
      "place skill at ~/.gemini/skills/<name>/SKILL.md (or project .agents/skills/)",
      "configure MCP in ~/.gemini/config/mcp_config.json",
      "browse via /skills and /mcp"
    ]
  },
  "headless": {
    "entrypoint": "agy -p \"<prompt>\"",
    "available": [
      "agy -m <model> (DOES take a --model flag, contra the legacy manifest)",
      "agy -c / --conversation <id> (resume)",
      "agy --add-dir <dir>, --dangerously-skip-permissions"
    ]
  },
  "sources": [
    "https://antigravity.google/docs/cli-using",
    "https://antigravitylab.net/en/articles/antigravity/antigravity-cli-agy-setup-and-slash-commands-getting-started",
    "https://www.datacamp.com/tutorial/antigravity-cli",
    "https://medium.com/google-cloud/configuring-mcp-servers-and-skills-for-antigravity-cli-and-ide-a938c7eebb78"
  ]
}
